// -------------------------------------------------------------------
// File:    appsettings.json
// Author:  N/A
// Created: n/A
// Purpose: Base configuration for SWIMS (production). Shell for git
//          commit — secrets (passwords, API keys, VAPID keys, connection
//          strings) must be supplied via user-secrets or environment in
//          actual deployments. appsettings.Development.json is the
//          authoritative structural reference.
// -------------------------------------------------------------------

{
  "App": {
    "PathBase": "/swims-test",
    "SetupCompleted": null,
    "Setup": {
      "GuardEnabled": "false"
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Identity": "Debug",
      "Microsoft.AspNetCore.Authentication": "Information"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/swims_.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "",
    "Domain": "gocd.mofpdomgov.gov"
  },

  "Auth": {
    "SeedOnStartup": false
  },

  "SuperAdminUser": {
    "Email": "superadmin@your.gov.dm",
    "Password": ""
  },
  "AdminUser": {
    "Email": "admin@your.gov.dm",
    "Password": ""
  },

  "StoredProcs": {
    "DefaultCommandTimeoutSeconds": 60,
    "ManualConnection": {
      "Encrypt": true,
      "TrustServerCertificate": true,
      "MultipleActiveResultSets": true,
      "ConnectTimeout": 15
    }
  },

  "Ldap": {
    "Server": "G0cddc3.gocd.mofpdomgov.gov",
    "Port": 389,
    "UseSsl": false,
    "UseStartTls": false, // Only upgrade 389 to TLS if the DC supports StartTLS
    "TryBothFormats": true, // When user types just "john", also try DOMAIN\john after john@UpnSuffix
    "NetbiosDomain": "GOCD", // NetBIOS name used for DOMAIN\user attempts (explicit beats guessing)
    "BaseDN": "DC=gocd,DC=mofpdomgov,DC=gov",
    "UpnSuffix": "dominica.gov.dm",
    "EnableRoleSync": false
  },

  "Emailing": {
    "Mode": "Smtp", // Austin override: switched from personal Graph to gmail project + app password

    "SmtpProfiles": {
      "ActiveProfile": "Gmail", // set mail profile here
      "Profiles": {
        "Gmail": {
          "Host": "smtp.gmail.com",
          "Port": 587,
          "UseStartTls": true,
          "UseSsl": false,
          "Username": "swimsdev@gmail.com",
          "Password": "",
          "DefaultFromAddress": "swimsdev@gmail.com",
          "DefaultFromName": "SWIMS", // Austin override: no "(Dev)" suffix in prod
          "DevPickupDirectory": null,
          "TemplateDirectory": "Templates/Email"
        },
        "Microsoft365": {
          "Host": "smtp.office365.com",
          "Port": 587,
          "UseStartTls": true,
          "UseSsl": false,
          "Username": "",
          "Password": null,
          "DefaultFromAddress": "",
          "DefaultFromName": "SWIMS",
          "DevPickupDirectory": null,
          "TemplateDirectory": "Templates/Email"
        },
        "LocalPickup": {
          "Host": null,
          "Port": 25,
          "UseStartTls": false,
          "UseSsl": false,
          "Username": null,
          "Password": null,
          "DefaultFromAddress": "no-reply@localhost",
          "DefaultFromName": "SWIMS (Pickup)",
          "DevPickupDirectory": ".smtp-outbox", // writes .eml files here instead of sending
          "TemplateDirectory": "Templates/Email"
        }
      }
    },

    "Graph": {
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "SenderUser": "",
      "SaveToSentItems": true,

      // Optional override; if omitted we'll fall back to the SMTP profile's template dir or "Templates/Email"
      "TemplateDirectory": "Templates/Email",
      "DefaultFromAddress": "service@yourdomain.com",
      "DefaultFromName": "SWIMS"
    },

    "StartupTest": {
      "Enabled": false,
      "To": "swimsdev@outlook.com",
      "TemplateKey": "StartupProbe",
      "Subject": "SWIMS started",
      "HtmlBody": "<p>SWIMS booted at <strong>{{Now}}</strong> on {{Hostname}} ({{Environment}}).</p>",
      "DelaySeconds": 0
    }
  },

  "WebPush": {
    "Subject": "mailto:it@yourdomain.com",
    "PublicKey": "",
    "PrivateKey": ""
  },

  "Reporting": {
    "ReportServerUrl": "http://gocdssr2/ReportServer",
    "ReportPathRoot": "/SWIMS_Report", // Austin override: user's /VCAS_Report was stale
    "UseReverseProxy": true,
    "ReverseProxyBasePath": "/ssrs",
    "UrlAccess": {
      "UseEmbed": true,
      "HideToolbar": true,
      "Zoom": "PageWidth"
    },
    "ServiceAccount": {
      "Domain": "GOV",
      "Username": "svc-ssrs",
      "Password": "<use-user-secrets>"
    }
  },

  "Elsa": {
    // Include the /elsa/api part per docs. Must match ElsaServer base address.
    "ServerUrl": "https://apps.gov.dm/elsa-server/elsa/api/",

    // Default admin API key when using UseAdminApiKey().
    "ApiKey": "",

    "Integration": {
      // ValidateOnStart() will block app boot if missing — supply via user-secrets or env.
      "NotificationsKey": ""
    }
  },

  "Notifications": {
    "Email": {
      "ImmediateEnabled": true,
      "MandatoryEventKeys": [
        "Swims.Events.Approvals.Pending.L1",
        "Swims.Events.Approvals.Pending.L2",
        "Swims.Events.Approvals.Pending.L3",
        "Swims.Events.Approvals.Pending.L4",
        "Swims.Events.Approvals.Pending.L5",
        "Swims.Events.Approvals.FinalApproved",
        "Swims.Events.Cases.Assigned",
        "Swims.Events.Identity.Users.Created",
        "Swims.Events.Identity.Users.Deleted",
        "Swims.Events.Identity.Users.RolesUpdated"
      ],
      "AllowEventKeys": [
        "Swims.Events.Cases.StatusChanged"
      ]
    }
  },

  "Support": {
    "Email": "support.apps@gov.dm",
    "Phone": "(767) 266-3310"
  },

  "EPPlus": {
    "ExcelPackage": {
      "License": "NonCommercialPersonal:SWIMS"
    }
  }
}
