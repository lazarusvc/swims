@page "/Portal/Logs/Sessions"
@{
    ViewData["title"] = "Session Logs";
    ViewData["subTitle"] = "Monitoring & Observability";
    ViewData["description"] = "View user sessions, including sign-in, last activity, logout, and active-session diagnostics.";
}

<div class="card basic-data-table">
    <div class="card-header d-flex align-items-center flex-wrap gap-2">
        <h5 class="card-title mb-0 me-auto">Session Logs</h5>

        <input id="flt-username"
               class="form-control form-control-sm"
               placeholder="Username"
               style="max-width:180px" />

        <input id="flt-from"
               type="datetime-local"
               class="form-control form-control-sm"
               style="max-width:200px"
               title="From (UTC)" />

        <input id="flt-to"
               type="datetime-local"
               class="form-control form-control-sm"
               style="max-width:200px"
               title="To (UTC)" />

        <input id="flt-contains"
               class="form-control form-control-sm"
               placeholder="IP / UA contains…"
               style="max-width:220px" />

        <div class="form-check ms-2">
            <input id="flt-active"
                   class="form-check-input"
                   type="checkbox" />
            <label class="form-check-label" for="flt-active">
                Active only
            </label>
        </div>

        <select id="flt-take"
                class="form-select form-select-sm"
                style="width:90px">
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>

        <button id="btn-apply"
                class="btn btn-sm btn-primary">
            Apply
        </button>

        <button id="btn-reset"
                class="btn btn-sm btn-outline-secondary">
            Reset
        </button>

        <a id="btn-csv"
           class="btn btn-sm btn-outline-primary"
           href="#">
            Export CSV
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table bordered-table mb-0 align-middle w-100"
                   id="tbl-sessions">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Username</th>
                        <th>Login</th>
                        <th>Last Seen</th>
                        <th>Logout</th>
                        <th>IP</th>
                        <th>UA</th>
                        <th>SID</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const qS = sel => document.querySelector(sel);
            const tbody = qS('#tbl-sessions tbody');

            const els = {
                username: qS('#flt-username'),
                from:     qS('#flt-from'),
                to:       qS('#flt-to'),
                contains: qS('#flt-contains'),
                active:   qS('#flt-active'),
                take:     qS('#flt-take')
            };

            let skip = 0;
            let take = 25;
            const dtLocalToIso = v => v ? new Date(v).toISOString() : '';

            const buildQuery = () => {
                const p = new URLSearchParams();
                p.set('skip', skip);
                p.set('take', take);

                if (els.username.value) p.set('username', els.username.value);
                if (els.from.value)     p.set('from', dtLocalToIso(els.from.value));
                if (els.to.value)       p.set('to', dtLocalToIso(els.to.value));
                if (els.contains.value) p.set('contains', els.contains.value);
                if (els.active.checked) p.set('activeOnly', 'true');

                return p.toString();
            };

            const load = async () => {
                const url = window.apiUrl(`/api/v1/ops/logs/sessions?${buildQuery()}`);
                const r = await fetch(url, { credentials: 'same-origin' });

                if (!r.ok) {
                    console.error('Failed to load sessions', r.status);
                    tbody.innerHTML = '<tr><td colspan="8" class="text-danger">Failed to load session logs.</td></tr>';
                    return;
                }

                const d = await r.json();
                const items = d.items || [];

                tbody.innerHTML = items.map(x => {
                    const ua = x.userAgent ?? '';
                    const uaShort = ua.length > 40 ? ua.slice(0, 40) + '…' : ua;
                    const sid = x.sessionId ?? '';
                    const sidShort = sid.length > 8 ? sid.slice(0, 8) + '…' : sid;

                    return `
                        <tr>
                            <td>${x.userId ?? ''}</td>
                            <td>${x.username ?? ''}</td>
                            <td>${x.loginUtc ? new Date(x.loginUtc).toLocaleString() : ''}</td>
                            <td>${x.lastSeenUtc ? new Date(x.lastSeenUtc).toLocaleString() : ''}</td>
                            <td>${x.logoutUtc ? new Date(x.logoutUtc).toLocaleString() : ''}</td>
                            <td>${x.ip ?? ''}</td>
                            <td title="${ua}">${uaShort}</td>
                            <td><code title="${sid}">${sidShort}</code></td>
                        </tr>`;
                }).join('');
            };

            const applyBtn = qS('#btn-apply');
            if (applyBtn) {
                applyBtn.onclick = () => {
                    skip = 0;
                    if (els.take) {
                        const parsed = parseInt(els.take.value, 10);
                        take = !Number.isNaN(parsed) && parsed > 0 ? parsed : 25;
                    }
                    load();
                };
            }

            const resetBtn = qS('#btn-reset');
            if (resetBtn) {
                resetBtn.onclick = () => {
                    els.username.value = '';
                    els.from.value = '';
                    els.to.value = '';
                    els.contains.value = '';
                    els.active.checked = false;
                    if (els.take) els.take.value = '25';
                    skip = 0;
                    take = 25;
                    load();
                };
            }

            const csvBtn = qS('#btn-csv');
            if (csvBtn) {
                csvBtn.onclick = (e) => {
                    e.preventDefault();
                    const csvUrl = window.apiUrl(`/api/v1/ops/logs/sessions.csv?${buildQuery()}`);
                    window.location.href = csvUrl;
                };
            }

            // initial
            load();
        })();
    </script>
}
