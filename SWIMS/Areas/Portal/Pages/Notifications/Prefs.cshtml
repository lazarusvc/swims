@page "/Portal/Notifications/Prefs"

@{
    ViewData["Title"] = "Notification Preferences";
    ViewData["title"] = "Notification Preferences";
    ViewData["subTitle"] = "My preferences";
    ViewData["description"] = "Configure your default notification channels and override settings per notification type.";
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="mb-0">Notification Preferences</h5>
    </div>

    <div class="card-body">
        <p class="text-secondary-light mb-4">
            Set your default channels and override per notification type.
        </p>

        <h6 class="fw-semibold mb-3">Global Defaults</h6>
        <div class="table-responsive mb-4">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="text-secondary-light">Scope</th>
                        <th>In-app</th>
                        <th>Email</th>
                        <th>Digest</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="fw-semibold">All notifications</span></td>
                        <td><input id="pref-global-inapp" class="form-check-input" type="checkbox" checked /></td>
                        <td><input id="pref-global-email" class="form-check-input" type="checkbox" /></td>
                        <td><input id="pref-global-digest" class="form-check-input" type="checkbox" /></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <h6 class="fw-semibold mb-3">Per Type</h6>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="text-secondary-light">Type</th>
                        <th>In-app</th>
                        <th>Email</th>
                        <th>Digest</th>
                    </tr>
                </thead>
                <tbody id="pref-rows"></tbody>
            </table>
        </div>
    </div>
</div>

<div class="col-12">
    <div class="card shadow-sm border-0 mt-3">
        <div class="card-body">
            <h6 class="fw-semibold mb-2">Browser Push Notifications</h6>
            <p class="text-secondary-light mb-3">
                Push notifications can appear even when SWIMS is not open (if supported by your browser/device).
            </p>

            <div class="d-flex gap-2 align-items-center flex-wrap">
                <button type="button" class="btn btn-primary btn-sm" id="btn-push-enable">Enable Push</button>
                <button type="button" class="btn btn-outline-danger btn-sm" id="btn-push-disable">Disable Push</button>
                <span class="text-secondary-light small" id="push-status"></span>
            </div>

            <div class="mt-2 small text-secondary-light">
                If you previously blocked push notifications, you may need to re-enable them in your browser settings.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/WowDash/js/notif-prefs.js" asp-append-version="true"></script>

    <script>
        (function () {
          async function setStatus() {
            const el = document.getElementById('push-status');
            if (!el) return;

            const perm = (typeof Notification !== 'undefined') ? Notification.permission : 'unsupported';
            let sub = 'unknown';

            if (window.SwimsPush?.status) {
              const s = await window.SwimsPush.status();
              sub = s.subscribed ? 'yes' : 'no';
            }

            el.textContent = `Permission: ${perm} • Subscribed: ${sub}`;
          }

          document.addEventListener('DOMContentLoaded', () => {
            setStatus();

            document.getElementById('btn-push-enable')?.addEventListener('click', async () => {
              await window.SwimsPush?.enable?.();
              await setStatus();
            });

            document.getElementById('btn-push-disable')?.addEventListener('click', async () => {
              await window.SwimsPush?.disable?.();
              await setStatus();
            });
          });
        })();
    </script>
}
