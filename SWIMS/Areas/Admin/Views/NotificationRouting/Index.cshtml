@model List<SWIMS.Models.Notifications.NotificationRoute>

@{
    ViewData["Title"] = "Notification Routing";
    ViewData["title"] = "Notification Routing";
    ViewData["subTitle"] = "Event routing rules";
    ViewData["description"] = "Configure which roles, permissions, and users receive notifications for each system event.";
    ViewData["BreadcrumbCurrentArea"] = "Admin";
    ViewData["BreadcrumbCurrentController"] = "NotificationRouting";
    ViewData["BreadcrumbCurrentAction"] = "Index";
}

<div class="card basic-data-table">
    <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <h5 class="card-title mb-0">Notification Routing</h5>
        <a asp-action="Create" class="btn btn-sm btn-primary d-flex align-items-center gap-1">
            <iconify-icon icon="lucide:plus" class="fs-14"></iconify-icon>
            <span>Create Route</span>
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Event Key</th>
                        <th>Type</th>
                        <th>Enabled</th>
                        <th>Roles</th>
                        <th>Perms</th>
                        <th>Users</th>
                        <th>Updated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="text-break">@r.EventKey</td>
                            <td>@r.Type</td>
                            <td>@(r.IsEnabled ? "Yes" : "No")</td>
                            <td>@r.Roles.Count</td>
                            <td>@r.Permissions.Count</td>
                            <td>@r.Users.Count</td>
                            <td>@r.UpdatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@r.Id">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-muted small mt-2">
            SuperAdmin is always notified for every event (hard rule).
        </div>
    </div>
</div>
