@model IEnumerable<SWIMS.Models.Reports.SwReport>

@{
    ViewData["title"] = "Reports (Admin)";
    ViewData["subTitle"] = "Manage report definitions";
    ViewData["description"] = "Configure which reports are available in SWIMS, how they are described, and who can see them.";

    ViewData["BreadcrumbCurrentArea"] = "Admin";
    ViewData["BreadcrumbCurrentController"] = "ReportsAdmin";
    ViewData["BreadcrumbCurrentAction"] = "Index";
}

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success alert-dismissible fade show mb-24" role="alert">
        @ok
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card basic-data-table">
    <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <h5 class="card-title mb-0">Reports</h5>

        <a asp-action="Create"
           class="btn btn-sm btn-primary d-flex align-items-center gap-1">
            <iconify-icon icon="lucide:plus" class="fs-14"></iconify-icon>
            <span>New Report</span>
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table bordered-table mb-0 align-middle w-100"
                   id="dataTable"
                   data-page-length="10">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Role</th>
                        <th>Params</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.Name</td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(r.Desc))
                                {
                                    <span class="text-muted">Not set</span>
                                }
                                else
                                {
                                    <div class="text-wrap text-break" style="max-width: 320px;">
                                        @r.Desc
                                    </div>
                                }
                            </td>
                            <td>@r.RoleId</td>
                            <td>
                                <a asp-area="Admin"
                                   asp-controller="ReportParams"
                                   asp-action="Index"
                                   asp-route-reportId="@r.Id"
                                   class="btn btn-xs btn-outline-secondary">
                                    Manage
                                </a>
                            </td>
                            <td class="text-center align-middle">
                                <div class="d-flex align-items-center gap-10 justify-content-center">
                                    <a asp-area="Admin"
                                       asp-controller="ReportsAdmin"
                                       asp-action="Edit"
                                       asp-route-id="@r.Id"
                                       class="bg-success-focus bg-hover-success-200 text-success-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                       title="Edit" aria-label="Edit">
                                        <iconify-icon icon="lucide:edit"></iconify-icon>
                                    </a>

                                    <form asp-area="Admin"
                                          asp-controller="ReportsAdmin"
                                          asp-action="Delete"
                                          asp-route-id="@r.Id"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Delete this report?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="remove-item-btn bg-danger-focus bg-hover-danger-200 text-danger-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle border-0"
                                                title="Delete" aria-label="Delete">
                                            <iconify-icon icon="mingcute:delete-2-line"></iconify-icon>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const reportsAdminTable = document.querySelector('#dataTable');
        if (reportsAdminTable) {
            new DataTable(reportsAdminTable);
        }
    </script>
}
