@model EndpointPolicyEditViewModel

@{
    ViewData["title"] = "Edit Endpoint Policy Assignment";
    ViewData["subTitle"] = "Edit Endpoint Policy Assignment";
    ViewData["description"] = "Update the policy assignment for this endpoint.";

    // Parent crumb → main index page
    ViewData["BreadcrumbParentTitle"] = "Endpoint Policy Assignments";
    ViewData["BreadcrumbParentArea"] = "Admin";
    ViewData["BreadcrumbParentController"] = "EndpointPolicies";
    ViewData["BreadcrumbParentAction"] = "Index";

    // Current page crumb
    ViewData["BreadcrumbCurrentArea"] = "Admin";
    ViewData["BreadcrumbCurrentController"] = "EndpointPolicies";
    ViewData["BreadcrumbCurrentAction"] = "Edit";
}


<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Policy</label>
        <select asp-for="PolicyName" asp-items="Model.Policies" class="form-select"></select>
    </div>

    @await Html.PartialAsync("../Shared/_MatchTypeFields", Model)

    <button class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
