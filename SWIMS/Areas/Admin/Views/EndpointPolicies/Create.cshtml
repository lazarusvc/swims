@model EndpointPolicyEditViewModel

@{
    ViewData["title"] = "Add Endpoint Policy Assignment";
    ViewData["subTitle"] = "Add Endpoint Policy Assignment";
    ViewData["description"] = "Assign an authorization policy to a specific endpoint.";

    // Parent crumb → main index page
    ViewData["BreadcrumbParentText"] = "Endpoint Policy Assignments";
    ViewData["BreadcrumbParentArea"] = "Admin";
    ViewData["BreadcrumbParentController"] = "EndpointPolicies";
    ViewData["BreadcrumbParentAction"] = "Index";

    // Current page crumb
    ViewData["BreadcrumbCurrentArea"] = "Admin";
    ViewData["BreadcrumbCurrentController"] = "EndpointPolicies";
    ViewData["BreadcrumbCurrentAction"] = "Create";
}


<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Policy</label>
        <select asp-for="PolicyName" class="form-select" asp-items="Model.Policies"></select>
    </div>

    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_MatchTypeFields.cshtml", Model)

    <div class="mt-3">
        <button class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
