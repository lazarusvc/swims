@model SWIMS.Models.Reports.SwReportParam

@{
    ViewData["title"] = "Create Parameter";
    ViewData["subTitle"] = "Create Parameter";
    ViewData["description"] = "Add a stored parameter that will be injected whenever this report is run.";

    ViewData["BreadcrumbParentTitle"] = "Report Parameters";
    ViewData["BreadcrumbParentController"] = "ReportParams";
    ViewData["BreadcrumbParentAction"] = "Index";
    ViewData["BreadcrumbParentRouteValues"] = 
        new Dictionary<string, string>
        {
            ["reportId"] = Model.SwReportId.ToString()
        };

    ViewData["BreadcrumbCurrentArea"] = "Admin";
    ViewData["BreadcrumbCurrentController"] = "ReportParams";
    ViewData["BreadcrumbCurrentAction"] = "Create";
    ViewData["BreadcrumbCurrentRouteValues"] = 
        new Dictionary<string, string>
        {
            ["reportId"] = Model.SwReportId.ToString()
        };

}

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success alert-dismissible fade show mb-24" role="alert">
        @ok
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Err"] is string er && !string.IsNullOrWhiteSpace(er))
{
    <div class="alert alert-danger alert-dismissible fade show mb-24" role="alert">
        @er
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <form asp-area="Admin"
              asp-controller="ReportParams"
              asp-action="Create"
              asp-route-reportId="@Model.SwReportId"
              method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="SwReportId" />

            <div class="mb-3">
                <label class="form-label">Param Key</label>
                <input asp-for="ParamKey" class="form-control" />
                <span asp-validation-for="ParamKey" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Param Value</label>
                <input asp-for="ParamValue" class="form-control" />
                <span asp-validation-for="ParamValue" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Data Type</label>
                <input asp-for="ParamDataType" class="form-control" placeholder="String / Integer / DateTime" />
            </div>

            <button class="btn btn-primary" type="submit">Create</button>
            <a class="btn btn-link" asp-action="Index" asp-route-reportId="@Model.SwReportId">Back</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
