@model IEnumerable<SWIMS.Models.SW_programTag>

@{
    ViewData["Title"] = "Program Tags";
    ViewData["title"] = "Lookups";
    ViewData["subTitle"] = "Program Tags";
    ViewData["description"] = "Manage program tag lookups used to group and filter programs.";

    ViewData["BreadcrumbCurrentController"] = "ProgramTags";
    ViewData["BreadcrumbCurrentAction"] = "Index";
}

@if (TempData["Ok"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show mb-24" role="alert">
        @ok
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card basic-data-table">
    <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <h5 class="card-title mb-0">Program Tags</h5>

        <a asp-action="Create"
           class="btn btn-sm btn-primary d-flex align-items-center gap-1">
            <iconify-icon icon="lucide:plus" class="fs-14"></iconify-icon>
            <span>New Tag</span>
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table bordered-table mb-0 align-middle w-100"
                   id="dataTable"
                   data-page-length="10">
                <thead>
                    <tr>
                        <th style="width: 140px;">Code</th>
                        <th>Name</th>
                        <th style="width: 120px;">Status</th>
                        <th style="width: 140px; white-space: nowrap;">Default (months)</th>
                        <th style="width: 80px; white-space: nowrap;">Sort</th>
                        <th class="text-center" style="width: 110px;">Actions</th>
                    </tr>

                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No program tags defined yet.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var t in Model)
                        {
                            var statusClass = t.is_active ? "bg-success" : "bg-secondary";
                            var statusText = t.is_active ? "Active" : "Inactive";

                            <tr>
                                <td class="fw-semibold">@t.code</td>
                                <td>@t.name</td>
                                <td>
                                    <span class="badge @statusClass">
                                        @statusText
                                    </span>
                                </td>
                                <td>@(t.default_benefit_months?.ToString() ?? "—")</td>
                                <td>@t.sort_order</td>
                                <td class="text-center align-middle">
                                    <div class="d-flex align-items-center gap-10 justify-content-center">
                                        <a asp-action="Details" asp-route-id="@t.Id"
                                           class="bg-info-focus bg-hover-info-200 text-info-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                           title="Details" aria-label="Details">
                                            <iconify-icon icon="iconamoon:eye-light"></iconify-icon>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@t.Id"
                                           class="bg-success-focus bg-hover-success-200 text-success-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                           title="Edit" aria-label="Edit">
                                            <iconify-icon icon="lucide:edit"></iconify-icon>
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@t.Id"
                                           class="remove-item-btn bg-danger-focus bg-hover-danger-200 text-danger-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                           title="Delete" aria-label="Delete">
                                            <iconify-icon icon="mingcute:delete-2-line"></iconify-icon>
                                        </a>
                                    </div>
                                </td>


                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const programTagsTable = new DataTable('#dataTable');
    </script>
}
