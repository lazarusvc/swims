@model SWIMS.Models.SW_programTag

@{
    ViewData["Title"] = "Edit Program Tag";
    ViewData["title"] = "Lookups";
    ViewData["subTitle"] = "Edit Program Tag";
    ViewData["description"] = "Update this program tag lookup.";

    ViewData["BreadcrumbParentTitle"] = "Program Tags";
    ViewData["BreadcrumbParentController"] = "ProgramTags";
    ViewData["BreadcrumbParentAction"] = "Index";

    ViewData["BreadcrumbCurrentController"] = "ProgramTags";
    ViewData["BreadcrumbCurrentAction"] = "Edit";
}

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="code" class="form-label"></label>
                    <input asp-for="code" class="form-control" />
                    <span asp-validation-for="code" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="name" class="form-label"></label>
                    <input asp-for="name" class="form-control" />
                    <span asp-validation-for="name" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="sort_order" class="form-label"></label>
                    <input asp-for="sort_order" class="form-control" type="number" />
                    <span asp-validation-for="sort_order" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="default_benefit_months" class="form-label"></label>
                    <input asp-for="default_benefit_months" class="form-control" type="number" min="1" max="120" />
                    <div class="form-text">
                        Optional. Used when no benefit period is captured from the primary application and no case override is set.
                    </div>
                    <span asp-validation-for="default_benefit_months" class="text-danger"></span>
                </div>

                <div class="col-md-3 d-flex align-items-center mt-3">
                    <div class="form-check">
                        <input asp-for="is_active" class="form-check-input" />
                        <label asp-for="is_active" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="ri-save-line align-bottom me-1"></i>
                    Save changes
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Back to list
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
