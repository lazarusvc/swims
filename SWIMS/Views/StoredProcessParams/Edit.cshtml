@model SWIMS.Models.ViewModels.StoredProcessParamEditViewModel

@{
    ViewData["title"] = "Edit Parameter";
    ViewData["subTitle"] = "Edit Parameter";
    ViewData["description"] = "Update a parameter definition for this stored process.";

    var proc = (SWIMS.Models.StoredProcess)ViewBag.Process;

    ViewData["BreadcrumbParentTitle"] = "Parameters";
    ViewData["BreadcrumbParentArea"] = "";
    ViewData["BreadcrumbParentController"] = "StoredProcessParams";
    ViewData["BreadcrumbParentAction"] = "Index";

    ViewData["BreadcrumbCurrentArea"] = "";
    ViewData["BreadcrumbCurrentController"] = "StoredProcessParams";
    ViewData["BreadcrumbCurrentAction"] = "Edit";
}

<h5 class="mb-3">Edit Parameter for: @proc.Name</h5>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="StoredProcessId" />

    <div class="mb-3">
        <label asp-for="Key" class="form-label"></label>
        <input asp-for="Key" class="form-control" />
        <span asp-validation-for="Key" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DataType" class="form-label"></label>
        <select asp-for="DataType" class="form-select" asp-items="new SelectList(SWIMS.Models.ViewModels.StoredProcDataTypes.Allowed)"></select>
        <span asp-validation-for="DataType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Value" class="form-label"></label>
        <input asp-for="Value" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a class="btn btn-outline-secondary" asp-action="Index" asp-route-processId="@proc.Id">Cancel</a>
</form>
