@model SWIMS.Models.StoredProcessParam

@{
    ViewData["title"] = "Delete Parameter";
    ViewData["subTitle"] = "Delete Parameter";
    ViewData["description"] = "This will delete this parameter from the stored process.";

    ViewData["BreadcrumbParentTitle"] = "Parameters";
    ViewData["BreadcrumbParentArea"] = "";
    ViewData["BreadcrumbParentController"] = "StoredProcessParams";
    ViewData["BreadcrumbParentAction"] = "Index";

    ViewData["BreadcrumbCurrentArea"] = "";
    ViewData["BreadcrumbCurrentController"] = "StoredProcessParams";
    ViewData["BreadcrumbCurrentAction"] = "Delete";
}

<dl class="row">
    <dt class="col-sm-3">Key</dt>
    <dd class="col-sm-9">@Model.Key</dd>
    <dt class="col-sm-3">Type</dt>
    <dd class="col-sm-9">@Model.DataType</dd>
    <dt class="col-sm-3">Value</dt>
    <dd class="col-sm-9">@Model.Value</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a class="btn btn-outline-secondary" asp-action="Index" asp-route-processId="@Model.StoredProcessId">Cancel</a>
</form>
