@using Microsoft.AspNetCore.Mvc.Rendering
@model IEnumerable<SWIMS.Models.StoredProcessParam>

@{
    ViewData["title"] = "Stored Process Parameters";
    ViewData["subTitle"] = "Stored Process Parameters";
    ViewData["description"] = "Manage parameters bound to stored processes.";

    ViewData["BreadcrumbParentText"] = "Stored Processes (Admin)";
    ViewData["BreadcrumbParentArea"] = "";
    ViewData["BreadcrumbParentController"] = "StoredProcessesAdmin";
    ViewData["BreadcrumbParentAction"] = "Index";

    ViewData["BreadcrumbCurrentArea"] = "";
    ViewData["BreadcrumbCurrentController"] = "StoredProcessParams";
    ViewData["BreadcrumbCurrentAction"] = "Index";

    var proc = ViewBag.Process as SWIMS.Models.StoredProcess;
    var processes = ViewBag.Processes as SelectList;
}

<form asp-action="Select" method="post" class="mb-3">
    @Html.AntiForgeryToken()
    <div class="input-group">
        <select class="form-select" name="processId" asp-items="processes">
            <option value="">-- Choose a stored process --</option>
        </select>
        <button class="btn btn-primary" type="submit">Load</button>
    </div>
</form>

@if (proc is null)
{
    <div class="alert alert-info">Select a stored process to view or edit its parameters.</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="mb-1">@proc.Name</h5>
            <p class="text-muted mb-0">@proc.Description</p>
        </div>
    </div>

    if (!Model.Any())
    {
        <div class="alert alert-secondary">No parameters defined yet.</div>

        <div class="d-flex flex-wrap gap-2 mt-2">
            <a class="btn btn-sm btn-success d-flex align-items-center gap-1"
               asp-action="Create" asp-route-processId="@proc.Id">
                <iconify-icon icon="lucide:plus" class="fs-14"></iconify-icon>
                <span>Add Parameter</span>
            </a>

            <a class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
               asp-area="" asp-controller="StoredProcessesAdmin" asp-action="Index">
                <iconify-icon icon="lucide:arrow-left" class="fs-14"></iconify-icon>
                <span>Back</span>
            </a>
        </div>
    }
    else
    {
        <div class="card basic-data-table">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0">Parameters</h5>

                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-sm btn-success d-flex align-items-center gap-1"
                       asp-action="Create" asp-route-processId="@proc.Id">
                        <iconify-icon icon="lucide:plus" class="fs-14"></iconify-icon>
                        <span>Add Parameter</span>
                    </a>
                    <a class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                       asp-area="" asp-controller="StoredProcessesAdmin" asp-action="Index">
                        <iconify-icon icon="mdi:arrow-left" class="fs-14"></iconify-icon>
                        <span>Back to Processes</span>
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table bordered-table mb-0 align-middle w-100"
                           id="dataTable"
                           data-page-length="10">
                        <thead>
                            <tr>
                                <th>Key</th>
                                <th>Type</th>
                                <th>Value</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td>@p.Key</td>
                                    <td>@p.DataType</td>
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(p.Value))
                                        {
                                            <span class="text-muted">None</span>
                                        }
                                        else
                                        {
                                            <div class="text-wrap text-break" style="max-width: 280px;">
                                                @p.Value
                                            </div>
                                        }
                                    </td>
                                    <td class="text-nowrap text-end">
                                        <a class="btn btn-secondary btn-sm"
                                           asp-action="Edit" asp-route-id="@p.Id">
                                            Edit
                                        </a>
                                        <a class="btn btn-danger btn-sm"
                                           asp-action="Delete" asp-route-id="@p.Id">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        const paramsTableEl = document.querySelector('#dataTable');
        if (paramsTableEl) {
            const storedProcessParamsTable = new DataTable('#dataTable');
        }
    </script>
}
