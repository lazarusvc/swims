@model SWIMS.Models.ViewModels.RunStoredProcessResultViewModel

@{
    ViewData["title"] = $"Results: {Model.Name}";
    ViewData["subTitle"] = $"Results: {Model.Name}";
    ViewData["description"] = Model.Description;

    ViewData["BreadcrumbParentText"] = "Stored Procedures";
    ViewData["BreadcrumbParentArea"] = "";
    ViewData["BreadcrumbParentController"] = "StoredProcesses";
    ViewData["BreadcrumbParentAction"] = "Index";

    ViewData["BreadcrumbCurrentArea"] = "";
    ViewData["BreadcrumbCurrentController"] = "StoredProcesses";
    ViewData["BreadcrumbCurrentAction"] = "RunResult";

    var hasRows = Model.Table != null && Model.Table.Rows.Count > 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Results: @Model.Name</h2>
    <div class="d-flex align-items-center">
        @if (hasRows && Model.ProcessId > 0)
        {
            <a class="btn btn-sm btn-outline-primary me-2"
               asp-action="Export"
               asp-route-id="@Model.ProcessId"
               asp-route-format="csv"
               asp-route-uid="@ViewBag.uid"
               asp-route-formId="@(ViewBag.formId ?? "")"
               asp-route-orgId="@(ViewBag.orgId ?? "")">
                Export CSV
            </a>
            <a class="btn btn-sm btn-outline-primary me-2"
               asp-action="Export"
               asp-route-id="@Model.ProcessId"
               asp-route-format="xlsx"
               asp-route-uid="@ViewBag.uid"
               asp-route-formId="@(ViewBag.formId ?? "")"
               asp-route-orgId="@(ViewBag.orgId ?? "")">
                Export XLSX
            </a>
            <a class="btn btn-sm btn-outline-primary me-2"
               asp-action="Export"
               asp-route-id="@Model.ProcessId"
               asp-route-format="txt"
               asp-route-uid="@ViewBag.uid"
               asp-route-formId="@(ViewBag.formId ?? "")"
               asp-route-orgId="@(ViewBag.orgId ?? "")">
                Export TXT
            </a>
        }
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<p class="text-muted">@Model.Description</p>

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}
else if (!hasRows)
{
    <div class="alert alert-info">Executed successfully. No rows returned.</div>
}
else
{
    <div class="alert alert-success small">
        Returned @Model.Table!.Rows.Count row@(Model.Table.Rows.Count == 1 ? "" : "s").
    </div>

    <div class="card basic-data-table mt-3">
        <div class="card-header">
            <h5 class="card-title mb-0">Result rows</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table bordered-table mb-0 align-middle w-100"
                       id="dataTable"
                       data-page-length="25">
                    <thead>
                        <tr>
                            @foreach (System.Data.DataColumn col in Model.Table.Columns)
                            {
                                <th>@col.ColumnName</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (System.Data.DataRow row in Model.Table.Rows)
                        {
                            <tr>
                                @foreach (var obj in row.ItemArray)
                                {
                                    <td>@(obj ?? "")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (hasRows)
    {
        <script>
            const runResultTable = new DataTable('#dataTable');
        </script>
    }
}
