@using System.Security.Claims

@{
    // Browser tab title only; no breadcrumb title/subTitle/description
    ViewData["Title"] = "SWIMS Home";

    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
}

<div class="row gy-4">
    <div class="col-12">
        <div class="card basic-data-table">
            <!-- Hero header area (inspired by Faqs.cshtml) -->
            <div class="card-header p-0 border-0">
                <div class="responsive-padding-40-150 bg-light-pink">
                    <div class="row gy-4 align-items-center">
                        <div class="col-xl-7">
                            <h4 class="mb-20">Welcome to the Social Welfare Information Management System (SWIMS)</h4>
                            <p class="mb-0 text-secondary-light max-w-634-px text-xl">
                                SWIMS is Dominica’s evolving platform for managing social assistance programmes, cases and payments
                                in a single, integrated system. It is designed to move social welfare delivery away from paper files
                                and scattered spreadsheets into a structured, traceable and data-driven workflow that better supports
                                households and the people who work with them.
                            </p>
                        </div>
                        <div class="col-xl-5 d-xl-block d-none">
                            @* You can replace this image with a SWIMS-specific illustration later *@
                            <img src="~/uploads/group-hug.jpg"
                                 alt="SWIMS overview illustration"
                                 class="img-fluid rounded-4 shadow-sm" />
                        </div>

                    </div>
                </div>
            </div>

            <!-- Main content area (tabs + accordions) -->
            <div class="card-body bg-base responsive-padding-40-150">
                <div class="row gy-4">
                    <div class="col-lg-4">
                        <div class="active-text-tab nav flex-column nav-pills bg-base shadow py-0 px-24 radius-12 border"
                             id="home-info-tabs" role="tablist" aria-orientation="vertical">

                            <button class="nav-link text-secondary-light fw-semibold text-xl px-0 py-16 border-bottom active"
                                    id="tab-about-swims"
                                    data-bs-toggle="pill"
                                    data-bs-target="#pane-about-swims"
                                    type="button"
                                    role="tab"
                                    aria-controls="pane-about-swims"
                                    aria-selected="true">
                                About SWIMS
                            </button>

                            <button class="nav-link text-secondary-light fw-semibold text-xl px-0 py-16"
                                    id="tab-governance"
                                    data-bs-toggle="pill"
                                    data-bs-target="#pane-governance"
                                    type="button"
                                    role="tab"
                                    aria-controls="pane-governance"
                                    aria-selected="false">
                                Governance &amp; data
                            </button>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="tab-content" id="home-info-tab-content">

                            <!-- ABOUT SWIMS -->
                            <div class="tab-pane fade show active"
                                 id="pane-about-swims"
                                 role="tabpanel"
                                 aria-labelledby="tab-about-swims"
                                 tabindex="0">

                                <div class="accordion" id="accordionAboutSwims">
                                    <div class="accordion-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button text-primary-light text-xl"
                                                    type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#about-q1"
                                                    aria-expanded="true"
                                                    aria-controls="about-q1">
                                                What is SWIMS?
                                            </button>
                                        </h2>
                                        <div id="about-q1"
                                             class="accordion-collapse collapse show"
                                             data-bs-parent="#accordionAboutSwims">
                                            <div class="accordion-body">
                                                SWIMS is the <strong>Social Welfare Information Management System</strong>,
                                                a platform designed to support Dominica’s social protection system.
                                                It brings together programmes, beneficiaries, cases and payments into a
                                                more integrated, transparent and auditable environment.
                                            </div>
                                        </div>
                                    </div>

                                    @* Removed “Who is leading the project?” per your request *@

                                    <div class="accordion-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button text-primary-light text-xl collapsed"
                                                    type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#about-q3"
                                                    aria-expanded="false"
                                                    aria-controls="about-q3">
                                                What stage is this environment?
                                            </button>
                                        </h2>
                                        <div id="about-q3"
                                             class="accordion-collapse collapse"
                                             data-bs-parent="#accordionAboutSwims">
                                            <div class="accordion-body">
                                                This environment represents an <strong>MVP and testing build</strong>.
                                                It is used for ongoing user acceptance testing and refinement
                                                ahead of full production launch. Screens, data and workflows may change
                                                as feedback is incorporated.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- GOVERNANCE & DATA -->
                            <div class="tab-pane fade"
                                 id="pane-governance"
                                 role="tabpanel"
                                 aria-labelledby="tab-governance"
                                 tabindex="0">

                                <div class="accordion" id="accordionGovernance">
                                    <div class="accordion-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button text-primary-light text-xl"
                                                    type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#gov-q1"
                                                    aria-expanded="true"
                                                    aria-controls="gov-q1">
                                                Who can access SWIMS?
                                            </button>
                                        </h2>
                                        <div id="gov-q1"
                                             class="accordion-collapse collapse show"
                                             data-bs-parent="#accordionGovernance">
                                            <div class="accordion-body">
                                                Access to SWIMS is role-based. Programme staff, social workers, managers
                                                and system administrators have different permissions and responsibilities.
                                                Guest users may see this landing page, but cannot access operational
                                                modules without an authorized account.
                                            </div>
                                        </div>
                                    </div>

                                    <div class="accordion-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button text-primary-light text-xl collapsed"
                                                    type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#gov-q2"
                                                    aria-expanded="false"
                                                    aria-controls="gov-q2">
                                                How is data handled?
                                            </button>
                                        </h2>
                                        <div id="gov-q2"
                                             class="accordion-collapse collapse"
                                             data-bs-parent="#accordionGovernance">
                                            <div class="accordion-body">
                                                SWIMS is designed to support secure handling of beneficiary and
                                                programme data. The final hosting, data protection and integration
                                                arrangements are defined by Government policy and project agreements.
                                                This environment may use sample or test data depending on the phase.
                                            </div>
                                        </div>
                                    </div>

                                    @* Removed “Where can I learn more?” per your request *@
                                </div>
                            </div>

                        </div> <!-- /tab-content -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
