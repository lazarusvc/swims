@{
    ViewData["title"] = "Social Welfare Information Management System (SWIMS)";
    ViewData["subTitle"] = "Home";
    ViewData["description"] = "Overview of the SWIMS project and entry points into the main modules.";
}

<div class="row gy-4">

    <!-- Hero / project overview -->
    <div class="col-12">
        <div class="card radius-12">
            <div class="card-body p-24">
                <div class="row g-4 align-items-center">
                    <div class="col-lg-8">
                        <p class="text-uppercase text-muted fs-12 mb-2">Project overview</p>
                        <h2 class="mb-3">Welcome to SWIMS</h2>

                        <p class="text-muted mb-3">
                            SWIMS is Dominica’s integrated Social Welfare Information Management System. It is being built
                            to digitize the full social assistance lifecycle – from intake and registration through
                            assessment, approval, payments, case management and reporting.
                        </p>

                        <ul class="list-unstyled mb-0 small">
                            <li class="d-flex gap-2 mb-2">
                                <span class="mt-1 text-primary">
                                    <iconify-icon icon="lucide:check-circle" class="fs-16"></iconify-icon>
                                </span>
                                <span>
                                    Single, shared view of programmes and beneficiaries across ISSU / DSS.
                                </span>
                            </li>
                            <li class="d-flex gap-2 mb-2">
                                <span class="mt-1 text-primary">
                                    <iconify-icon icon="lucide:check-circle" class="fs-16"></iconify-icon>
                                </span>
                                <span>
                                    Structured workflows for applications, approvals and payments, aligned with the FRD.
                                </span>
                            </li>
                            <li class="d-flex gap-2 mb-2">
                                <span class="mt-1 text-primary">
                                    <iconify-icon icon="lucide:check-circle" class="fs-16"></iconify-icon>
                                </span>
                                <span>
                                    Case management and monitoring tools to support social workers in the field.
                                </span>
                            </li>
                            <li class="d-flex gap-2">
                                <span class="mt-1 text-primary">
                                    <iconify-icon icon="lucide:check-circle" class="fs-16"></iconify-icon>
                                </span>
                                <span>
                                    Reporting foundations for accountability to Government and development partners.
                                </span>
                            </li>
                        </ul>
                    </div>

                    <div class="col-lg-4">
                        <div class="border rounded-3 p-16 bg-light-subtle small h-100">
                            <p class="fw-semibold mb-1">Current environment</p>
                            <p class="text-muted mb-2">
                                This instance is for configuration and internal user testing. Data and flows may change
                                as the project moves through design, piloting and rollout.
                            </p>

                            <p class="mb-2">
                                <span class="badge bg-primary-subtle text-primary">
                                    MVP – Case &amp; forms modules
                                </span>
                            </p>

                            <p class="mb-0 text-muted">
                                Signed in as <strong>@User.Identity?.Name</strong>
                            </p>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <!-- Quick actions -->
                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                    <div>
                        <p class="fw-semibold mb-1">Quick actions</p>
                        <p class="text-muted mb-0 small">
                            Use these shortcuts to jump straight into the main working areas of the system.
                        </p>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Home"
                           asp-action="ProgramDashboard"
                           class="btn btn-primary btn-sm">
                            <iconify-icon icon="mdi:view-dashboard-outline" class="me-1"></iconify-icon>
                            Programs dashboard
                        </a>

                        <a asp-controller="Cases"
                           asp-action="Index"
                           class="btn btn-outline-primary btn-sm">
                            <iconify-icon icon="mdi:briefcase-outline" class="me-1"></iconify-icon>
                            Case module
                        </a>

                        <a asp-controller="Reports"
                           asp-action="Index"
                           class="btn btn-outline-secondary btn-sm">
                            <iconify-icon icon="mdi:chart-bar" class="me-1"></iconify-icon>
                            Reports
                        </a>

                        <a asp-controller="Setup"
                           asp-action="Index"
                           class="btn btn-soft-secondary btn-sm">
                            <iconify-icon icon="mdi:cog-outline" class="me-1"></iconify-icon>
                            System setup
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- High-level flow explanation -->
    <div class="col-12">
        <div class="card radius-12">
            <div class="card-body p-24">
                <div class="row g-3">
                    <div class="col-xl-4 col-lg-6">
                        <div class="border rounded-3 p-16 h-100">
                            <p class="text-xs text-muted text-uppercase mb-1">1. Configure</p>
                            <h5 class="mb-2">Organisations, sites &amp; teams</h5>
                            <p class="text-sm text-muted mb-0">
                                Define organisations, offices and user roles so that approvals, payments and cases
                                reflect the real-world structure of ISSU / DSS.
                            </p>
                        </div>
                    </div>

                    <div class="col-xl-4 col-lg-6">
                        <div class="border rounded-3 p-16 h-100">
                            <p class="text-xs text-muted text-uppercase mb-1">2. Design</p>
                            <h5 class="mb-2">Programmes &amp; forms</h5>
                            <p class="text-sm text-muted mb-0">
                                Configure programme tags and form types, and design online forms for intake,
                                application, assessment and monitoring using the form builder.
                            </p>
                        </div>
                    </div>

                    <div class="col-xl-4 col-lg-6">
                        <div class="border rounded-3 p-16 h-100">
                            <p class="text-xs text-muted text-uppercase mb-1">3. Operate</p>
                            <h5 class="mb-2">Applications, cases &amp; payments</h5>
                            <p class="text-sm text-muted mb-0">
                                Use the Programs dashboard to launch forms, create cases, manage approvals
                                and trigger payment instructions for approved beneficiaries.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="mt-4 border-top pt-3">
                    <p class="text-xs text-muted mb-1">Need a deeper dive?</p>
                    <p class="text-sm text-muted mb-0">
                        Refer to the Concept Note and Functional Requirements Document (FRD) for full details on scope,
                        roles and data flows. This home page is intended as a quick orientation for day-to-day users.
                    </p>
                </div>
            </div>
        </div>
    </div>

</div>
