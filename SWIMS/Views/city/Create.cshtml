@model SWIMS.Models.SW_city

@{
    ViewData["title"] = "New city";
    ViewData["subTitle"] = "Add a new city or locality.";
    ViewData["description"] = "Create a city entry that can be used in addresses, forms and programme configuration across SWIMS.";
}

<div class="row">
    <div class="col-xl-6 col-lg-7">
        <div class="card radius-12">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0">Create city</h5>

                <a asp-action="Index"
                   class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                    <iconify-icon icon="lucide:arrow-left" class="fs-14"></iconify-icon>
                    <span>Back to list</span>
                </a>
            </div>

            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3 row">
                        <label asp-for="name" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="name" class="form-control" />
                            <span asp-validation-for="name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Create city
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
