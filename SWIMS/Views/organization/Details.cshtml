@model SWIMS.Models.SW_organization

@{
    ViewData["title"] = "Village council details";
    ViewData["subTitle"] = "View configuration for this local organisation.";
    ViewData["description"] = "Review the stored details for this village council, including its reference code, name, type and active status.";
}

<div class="row">
    <div class="col-xl-7 col-lg-8">
        <div class="card radius-12">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0">Village council details</h5>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:edit" class="fs-14"></iconify-icon>
                        <span>Edit</span>
                    </a>

                    <a asp-action="Index"
                       class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:list" class="fs-14"></iconify-icon>
                        <span>Back to list</span>
                    </a>
                </div>
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.vendor_id)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.vendor_id)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.name)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.name)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.type)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.type)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.active)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.active)
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
