@model SWIMS.Models.SW_organization

@{
    ViewData["title"] = "Edit village council";
    ViewData["subTitle"] = "Update this local organisation.";
    ViewData["description"] = "Adjust the details of this village council or local organisation. Changes here affect how it appears in forms, programme configuration and cases.";
}

<div class="row">
    <div class="col-xl-7 col-lg-8">
        <div class="card radius-12">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0">Edit village council</h5>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Details"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:info" class="fs-14"></iconify-icon>
                        <span>View details</span>
                    </a>

                    <a asp-action="Index"
                       class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:list" class="fs-14"></iconify-icon>
                        <span>Back to list</span>
                    </a>
                </div>
            </div>

            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3 row">
                        <label asp-for="vendor_id" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="vendor_id" class="form-control" />
                            <span asp-validation-for="vendor_id" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="name" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="name" class="form-control" />
                            <span asp-validation-for="name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="type" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="type" class="form-control" />
                            <span asp-validation-for="type" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="active" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="active" class="form-control" />
                            <span asp-validation-for="active" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Save changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
