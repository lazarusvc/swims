@model SWIMS.Models.SW_formType

@{
    ViewData["title"] = "Delete form type";
    ViewData["subTitle"] = "Confirm removal of this form classification.";
    ViewData["description"] = "Deleting a form type removes it from the lookup list. Only proceed if you are sure it is no longer required by forms, cases or reports.";
}

<div class="row">
    <div class="col-xl-7 col-lg-8">
        <div class="card radius-12 border-danger-subtle">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0 text-danger">Delete form type</h5>

                <a asp-action="Index"
                   class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                    <iconify-icon icon="lucide:arrow-left" class="fs-14"></iconify-icon>
                    <span>Back to list</span>
                </a>
            </div>

            <div class="card-body">
                <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
                    <iconify-icon icon="lucide:alert-triangle" class="fs-18 mt-1"></iconify-icon>
                    <div>
                        <strong>Are you sure you want to delete this form type?</strong>
                        <div class="small">
                            This action cannot be undone. Check the details below before confirming deletion.
                        </div>
                    </div>
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(m => m.code)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(m => m.code)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(m => m.name)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(m => m.name)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        Status
                    </dt>
                    <dd class="col-sm-9">
                        @if (Model.is_active)
                        {
                            <span class="badge bg-success-subtle text-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                        }
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(m => m.sort_order)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(m => m.sort_order)
                    </dd>
                </dl>

                <form asp-action="Delete" method="post" class="d-flex justify-content-end gap-2">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-danger">
                        Yes, delete this form type
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
