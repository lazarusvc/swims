@model SWIMS.Models.SW_financial_institution

@{
    ViewData["title"] = "Financial institution details";
    ViewData["subTitle"] = "View configuration for this bank or partner.";
    ViewData["description"] = "Review the stored details for this financial institution, including its name and primary contact email.";
}

<div class="row">
    <div class="col-xl-6 col-lg-7">
        <div class="card radius-12">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0">Financial institution details</h5>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:edit" class="fs-14"></iconify-icon>
                        <span>Edit</span>
                    </a>

                    <a asp-action="Index"
                       class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:list" class="fs-14"></iconify-icon>
                        <span>Back to list</span>
                    </a>
                </div>
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.name)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.name)
                    </dd>

                    <dt class="col-sm-4 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.email)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.email)
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
