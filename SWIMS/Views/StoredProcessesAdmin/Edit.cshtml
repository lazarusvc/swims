@model SWIMS.Models.ViewModels.StoredProcessEditViewModel

@{
    ViewData["title"] = "Edit Stored Process";
    ViewData["subTitle"] = "Edit Stored Process";
    ViewData["description"] = "Update the stored process definition and connection details.";

    ViewData["BreadcrumbParentTitle"] = "Stored Processes (Admin)";
    ViewData["BreadcrumbParentArea"] = "";
    ViewData["BreadcrumbParentController"] = "StoredProcessesAdmin";
    ViewData["BreadcrumbParentAction"] = "Index";

    ViewData["BreadcrumbCurrentArea"] = "";
    ViewData["BreadcrumbCurrentController"] = "StoredProcessesAdmin";
    ViewData["BreadcrumbCurrentAction"] = "Edit";
}

<p class="text-muted">Current: <code>@Model.ConnectionSummary</code></p>
<p class="text-muted">To change SQL login, enter new values; leave blank to keep existing.</p>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="ExcludeHeadersOnExport" class="form-check-input" />
        <label asp-for="ExcludeHeadersOnExport" class="form-check-label">Exclude headers on CSV export</label>
        <div class="form-text">Check this for bank files or other exports where the consumer doesn't want a header row.</div>
    </div>

    <fieldset class="border p-3 mb-3">
        <legend class="float-none w-auto px-2">Connection (Option A)</legend>
        <div class="mb-2">
            <label asp-for="ConnectionKey" class="form-label"></label>
            <input asp-for="ConnectionKey" class="form-control" placeholder="(Optional) Name from appsettings ConnectionStrings" />
        </div>
    </fieldset>

    <fieldset class="border p-3 mb-3">
        <legend class="float-none w-auto px-2">Connection (Option B)</legend>
        <div class="row g-2">
            <div class="col-md-6">
                <label asp-for="DataSource" class="form-label"></label>
                <input asp-for="DataSource" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Database" class="form-label"></label>
                <input asp-for="Database" class="form-control" />
            </div>
        </div>
        <div class="row g-2 mt-1">
            <div class="col-md-6">
                <label asp-for="DbUser" class="form-label"></label>
                <input asp-for="DbUser" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="DbPassword" class="form-label"></label>
                <input asp-for="DbPassword" class="form-control" />
            </div>
        </div>
    </fieldset>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
