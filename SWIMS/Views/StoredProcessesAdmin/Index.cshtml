@model IEnumerable<SWIMS.Models.StoredProcess>

@{
    ViewData["title"] = "Stored Processes (Admin)";
    ViewData["subTitle"] = "Stored Processes (Admin)";
    ViewData["description"] = "Administer stored process definitions and their connections.";

    ViewData["BreadcrumbCurrentArea"] = "";
    ViewData["BreadcrumbCurrentController"] = "StoredProcessesAdmin";
    ViewData["BreadcrumbCurrentAction"] = "Index";
}

<div class="card basic-data-table">
    <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <h5 class="card-title mb-0">Stored Processes (Admin)</h5>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-sm btn-success d-flex align-items-center gap-1"
               asp-action="Create">
                <iconify-icon icon="lucide:plus" class="fs-14"></iconify-icon>
                <span>Create Process</span>
            </a>

            <a class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
               asp-area="" asp-controller="StoredProcesses" asp-action="Index">
                <iconify-icon icon="mdi:play-circle-outline" class="fs-14"></iconify-icon>
                <span>Run View</span>
            </a>
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table bordered-table mb-0 align-middle w-100"
                   id="dataTable"
                   data-page-length="10">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Connection</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.Name</td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(p.Description))
                                {
                                    <span class="text-muted">No description</span>
                                }
                                else
                                {
                                    <div class="text-wrap text-break" style="max-width: 360px;">
                                        @p.Description
                                    </div>
                                }
                        </td>
                        <td>
                            @(string.IsNullOrWhiteSpace(p.ConnectionKey)
                                                        ? $"{p.DataSource}/{p.Database}"
                                                        : p.ConnectionKey)
                            </td>
                            <td class="text-nowrap text-end">
                                <a class="btn btn-primary btn-sm"
                                   asp-area="" asp-controller="StoredProcessParams" asp-action="Index"
                                   asp-route-processId="@p.Id">
                                    Params
                                </a>
                                <a class="btn btn-secondary btn-sm"
                                   asp-action="Edit" asp-route-id="@p.Id">
                                    Edit
                                </a>
                                <a class="btn btn-danger btn-sm"
                                   asp-action="Delete" asp-route-id="@p.Id">
                                    Delete
                                </a>
                                <a class="btn btn-outline-info btn-sm"
                                   asp-area="" asp-controller="StoredProcesses" asp-action="Run" asp-route-id="@p.Id">
                                    Run
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const storedProcessesAdminTable = new DataTable('#dataTable');
    </script>
}
