@model SWIMS.Services.Setup.SetupSummary
@using SWIMS.Services.Setup

@{
    // Browser tab title
    ViewData["Title"] = "System Setup & Health";

    // WowDash breadcrumb/header wiring
    ViewData["title"] = "System Setup & Health";
    ViewData["subTitle"] = "Environment & configuration checks";
    ViewData["description"] = "First-run checks for configuration, database connectivity, and EF Core migrations.";

    // Breadcrumb routing for this page
    ViewData["BreadcrumbCurrentController"] = "Setup";
    ViewData["BreadcrumbCurrentAction"] = "Index";

    var checks = Model.Checks ?? Array.Empty<SetupCheck>();

    var okChecks = checks.Where(c => c.Status == SetupCheckStatus.Ok).ToList();
    var warningChecks = checks.Where(c => c.Status == SetupCheckStatus.Warning).ToList();
    var errorChecks = checks.Where(c => c.Status == SetupCheckStatus.Error).ToList();
}

<div class="row">
    <div class="col-12">

        <div class="card mb-4">
            <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <h5 class="card-title mb-1">System Setup &amp; Health</h5>
                    <p class="fs-13 mb-0 text-muted">
                        First-run checks for configuration, database connectivity, and EF Core migrations.
                    </p>
                </div>

                <div class="d-flex align-items-center flex-wrap gap-2">
                    <span class="badge bg-soft-primary text-primary">
                        Environment: @Model.EnvironmentName
                    </span>

                    @if (Model.IsConfigured)
                    {
                        <span class="badge bg-soft-success text-success d-inline-flex align-items-center gap-1">
                            <iconify-icon icon="tabler:check" class="fs-16"></iconify-icon>
                            <span>Ready</span>
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-soft-warning text-warning d-inline-flex align-items-center gap-1">
                            <iconify-icon icon="tabler:alert-triangle" class="fs-16"></iconify-icon>
                            <span>Setup required</span>
                        </span>
                    }
                </div>
            </div>

            <div class="card-body">

                <div class="alert @(Model.IsConfigured ? "alert-soft-success" : "alert-soft-warning") mb-4">
                    @if (Model.IsConfigured)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <iconify-icon icon="tabler:circle-check" class="fs-18 text-success"></iconify-icon>
                            <div>
                                <h6 class="mb-1">Everything looks good.</h6>
                                <p class="mb-0 fs-13">
                                    All core checks passed. You can safely continue to use SWIMS.
                                    This page remains available under <code>/setup</code> for future diagnostics.
                                </p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2">
                            <iconify-icon icon="tabler:alert-triangle" class="fs-18 text-warning"></iconify-icon>
                            <div>
                                <h6 class="mb-1">Some checks need attention.</h6>
                                <p class="mb-0 fs-13">
                                    Review the blocking issues and warnings below. Once they are resolved,
                                    this page will show as fully configured.
                                </p>
                            </div>
                        </div>
                    }
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="border rounded-3 p-3 d-flex flex-column gap-1 h-100">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="fs-12 text-muted text-uppercase">OK</span>
                                <iconify-icon icon="tabler:circle-check" class="text-success fs-18"></iconify-icon>
                            </div>
                            <div class="fs-24 fw-semibold">@okChecks.Count</div>
                            <p class="mb-0 fs-12 text-muted">
                                Non-blocking checks that passed successfully.
                            </p>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="border rounded-3 p-3 d-flex flex-column gap-1 h-100">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="fs-12 text-muted text-uppercase">Warnings</span>
                                <iconify-icon icon="tabler:alert-circle" class="text-warning fs-18"></iconify-icon>
                            </div>
                            <div class="fs-24 fw-semibold">@warningChecks.Count</div>
                            <p class="mb-0 fs-12 text-muted">
                                Non-blocking issues. Recommended to review and clear where possible.
                            </p>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="border rounded-3 p-3 d-flex flex-column gap-1 h-100">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="fs-12 text-muted text-uppercase">Errors</span>
                                <iconify-icon icon="tabler:circle-x" class="text-danger fs-18"></iconify-icon>
                            </div>
                            <div class="fs-24 fw-semibold">@errorChecks.Count</div>
                            <p class="mb-0 fs-12 text-muted">
                                Blocking issues that prevent the app from being considered fully configured.
                            </p>
                        </div>
                    </div>
                </div>

                @if (errorChecks.Any())
                {
                    <div class="mb-4">
                        <h6 class="mb-2 d-flex align-items-center gap-2 text-danger">
                            <iconify-icon icon="tabler:circle-x" class="fs-18"></iconify-icon>
                            <span>Blocking issues</span>
                        </h6>

                        <div class="row g-3">
                            @foreach (var check in errorChecks)
                            {
                                <div class="col-md-6">
                                    <div class="border border-danger-subtle bg-soft-danger p-3 rounded-3 h-100">
                                        <div class="fw-semibold mb-1">@check.Name</div>

                                        @if (!string.IsNullOrWhiteSpace(check.Description))
                                        {
                                            <p class="mb-1 fs-13">@check.Description</p>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(check.Details))
                                        {
                                            <p class="mb-0 fs-12 text-danger">
                                                @check.Details
                                            </p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (warningChecks.Any())
                {
                    <div class="mb-4">
                        <h6 class="mb-2 d-flex align-items-center gap-2 text-warning">
                            <iconify-icon icon="tabler:alert-circle" class="fs-18"></iconify-icon>
                            <span>Warnings &amp; non-blocking issues</span>
                        </h6>

                        <div class="row g-3">
                            @foreach (var check in warningChecks)
                            {
                                <div class="col-md-6">
                                    <div class="border border-warning-subtle bg-soft-warning p-3 rounded-3 h-100">
                                        <div class="fw-semibold mb-1">@check.Name</div>

                                        @if (!string.IsNullOrWhiteSpace(check.Description))
                                        {
                                            <p class="mb-1 fs-13">@check.Description</p>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(check.Details))
                                        {
                                            <p class="mb-0 fs-12 text-warning">
                                                @check.Details
                                            </p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (okChecks.Any())
                {
                    <div class="mb-2">
                        <h6 class="mb-2 d-flex align-items-center gap-2 text-success">
                            <iconify-icon icon="tabler:circle-check" class="fs-18"></iconify-icon>
                            <span>Successful checks</span>
                        </h6>

                        <div class="row g-2">
                            @foreach (var check in okChecks)
                            {
                                <div class="col-md-6 col-xl-4">
                                    <div class="border border-success-subtle bg-soft-success p-2 rounded-3 h-100">
                                        <div class="d-flex align-items-start gap-2">
                                            <iconify-icon icon="tabler:check" class="fs-16 mt-1 text-success"></iconify-icon>
                                            <div>
                                                <div class="fw-semibold fs-13">@check.Name</div>

                                                @if (!string.IsNullOrWhiteSpace(check.Details))
                                                {
                                                    <p class="mb-0 fs-12 text-muted">
                                                        @check.Details
                                                    </p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (!checks.Any())
                {
                    <p class="text-muted mb-0">
                        No setup checks were returned. This usually indicates a configuration issue with the setup service.
                    </p>
                }

            </div>
        </div>

        <div class="alert alert-soft-info mt-2">
            <h6 class="mb-1">Typical first-run sequence</h6>
            <ol class="mb-0 fs-13 ps-3">
                <li>
                    Configure <code>ConnectionStrings:DefaultConnection</code>
                    and ensure SQL Server is reachable.
                </li>
                <li>
                    Apply EF Core migrations for all contexts
                    (Identity, Core, StoredProcs, Reports).
                </li>
                <li>
                    Verify the bootstrap admin user and initial access policy,
                    and confirm email settings in the <code>Emailing</code> section.
                </li>
                <li>
                    Refresh this page. When all blocking issues are cleared,
                    the app is considered fully configured.
                </li>
            </ol>
        </div>

    </div>
</div>
