@model SWIMS.Models.SW_identity

@{
    ViewData["title"] = "Edit site identity";
    ViewData["subTitle"] = "Update this organisation grouping.";
    ViewData["description"] = "Adjust the name, branding and metadata for this site identity. Changes here affect how linked forms and programmes are presented to users in SWIMS.";
}

<div class="row">
    <div class="col-xl-7 col-lg-8">
        <div class="card radius-12">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0">Edit site identity</h5>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Details"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:info" class="fs-14"></iconify-icon>
                        <span>View details</span>
                    </a>

                    <a asp-action="Index"
                       class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:list" class="fs-14"></iconify-icon>
                        <span>Back to list</span>
                    </a>
                </div>
            </div>

            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3 row">
                        <label asp-for="name" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="name" class="form-control" />
                            <span asp-validation-for="name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="desc" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="desc" class="form-control" />
                            <span asp-validation-for="desc" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="logo" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="logo" class="form-control" />
                            <span asp-validation-for="logo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="media_01" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="media_01" class="form-control" />
                            <span asp-validation-for="media_01" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="media_02" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="media_02" class="form-control" />
                            <span asp-validation-for="media_02" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="media_03" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="media_03" class="form-control" />
                            <span asp-validation-for="media_03" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="header" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="header" class="form-control" />
                            <span asp-validation-for="header" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="signature" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="signature" class="form-control" />
                            <span asp-validation-for="signature" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Save changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
