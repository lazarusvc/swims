@model SWIMS.Models.SW_identity

@{
    ViewData["title"] = "Delete site identity";
    ViewData["subTitle"] = "Confirm removal of this organisation grouping.";
    ViewData["description"] = "Deleting a site identity may affect how forms and programmes are grouped in SWIMS. Only proceed if you are sure this grouping is no longer required.";
}

<div class="row">
    <div class="col-xl-7 col-lg-8">
        <div class="card radius-12 border-danger-subtle">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0 text-danger">Delete site identity</h5>

                <a asp-action="Index"
                   class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                    <iconify-icon icon="lucide:arrow-left" class="fs-14"></iconify-icon>
                    <span>Back to list</span>
                </a>
            </div>

            <div class="card-body">
                <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
                    <iconify-icon icon="lucide:alert-triangle" class="fs-18 mt-1"></iconify-icon>
                    <div>
                        <strong>Are you sure you want to delete this site identity?</strong>
                        <div class="small">
                            This action cannot be undone. Any forms or configurations that reference this
                            identity will no longer show it as a grouping option.
                        </div>
                    </div>
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.name)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.name)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.desc)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.desc)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.logo)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.logo)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.media_01)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.media_01)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.media_02)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.media_02)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.media_03)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.media_03)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.header)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.header)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.signature)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.signature)
                    </dd>
                </dl>

                <form asp-action="Delete" method="post" class="d-flex justify-content-end gap-2">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-danger">
                        Yes, delete this site identity
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
