@model SWIMS.Models.SW_identity

@{
    ViewData["title"] = "New site identity";
    ViewData["subTitle"] = "Create a new organisation grouping.";
    ViewData["description"] = "Define a site identity to represent a ministry, department or agency. Forms and programmes can then be attached to this identity for clearer grouping and reporting.";
}

<div class="row">
    <div class="col-xl-7 col-lg-8">
        <div class="card radius-12">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0">Create site identity</h5>

                <a asp-action="Index"
                   class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                    <iconify-icon icon="lucide:arrow-left" class="fs-14"></iconify-icon>
                    <span>Back to list</span>
                </a>
            </div>

            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3 row">
                        <label asp-for="name" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="name" class="form-control" placeholder="Ministry / department name" />
                            <span asp-validation-for="name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="desc" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="desc" class="form-control" placeholder="Short description" />
                            <span asp-validation-for="desc" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="logo" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="logo" class="form-control" placeholder="Logo path or URL" />
                            <span asp-validation-for="logo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="media_01" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="media_01" class="form-control" placeholder="Optional media asset 1" />
                            <span asp-validation-for="media_01" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="media_02" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="media_02" class="form-control" placeholder="Optional media asset 2" />
                            <span asp-validation-for="media_02" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="media_03" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="media_03" class="form-control" placeholder="Optional media asset 3" />
                            <span asp-validation-for="media_03" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="header" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="header" class="form-control" placeholder="Header text or caption" />
                            <span asp-validation-for="header" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="signature" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="signature" class="form-control" placeholder="Signature or footer text" />
                            <span asp-validation-for="signature" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Create site identity
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
