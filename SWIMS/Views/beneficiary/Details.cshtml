@model SWIMS.Models.SW_beneficiary

@{
    ViewData["title"] = "Beneficiary details";
    ViewData["subTitle"] = "View record details for this beneficiary.";
    ViewData["description"] = "Review the key identifying and contact information stored for this beneficiary.";
}

<div class="row">
    <div class="col-xl-7 col-lg-8">
        <div class="card radius-12">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0">Beneficiary details</h5>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:edit" class="fs-14"></iconify-icon>
                        <span>Edit</span>
                    </a>

                    <a asp-action="Index"
                       class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:list" class="fs-14"></iconify-icon>
                        <span>Back to list</span>
                    </a>
                </div>
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.uuid)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.uuid)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.first_name)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.first_name)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.middle_name)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.middle_name)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.last_name)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.last_name)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.dob)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.dob)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.gender)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.gender)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.martial_status)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.martial_status)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.id_number)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.id_number)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.telephone_number)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.telephone_number)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.status)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.status)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.approved_amount)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.approved_amount)
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
