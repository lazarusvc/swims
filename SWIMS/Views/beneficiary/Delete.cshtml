@model SWIMS.Models.SW_beneficiary

@{
    ViewData["title"] = "Delete beneficiary";
    ViewData["subTitle"] = "Confirm removal of this beneficiary record.";
    ViewData["description"] = "Deleting a beneficiary removes this record from the SWIMS registry. Only proceed if you are sure this record is no longer required.";
}

<div class="row">
    <div class="col-xl-7 col-lg-8">
        <div class="card radius-12 border-danger-subtle">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h5 class="card-title mb-0 text-danger">Delete beneficiary</h5>

                <a asp-action="Index"
                   class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                    <iconify-icon icon="lucide:arrow-left" class="fs-14"></iconify-icon>
                    <span>Back to list</span>
                </a>
            </div>

            <div class="card-body">
                <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
                    <iconify-icon icon="lucide:alert-triangle" class="fs-18 mt-1"></iconify-icon>
                    <div>
                        <strong>Are you sure you want to delete this beneficiary?</strong>
                        <div class="small">
                            This action cannot be undone. Check the details below before confirming deletion.
                        </div>
                    </div>
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.uuid)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.uuid)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.first_name)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.first_name)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.middle_name)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.middle_name)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.last_name)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.last_name)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.dob)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.dob)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.gender)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.gender)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.martial_status)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.martial_status)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.id_number)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.id_number)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.telephone_number)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.telephone_number)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.status)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.status)
                    </dd>

                    <dt class="col-sm-3 text-muted text-uppercase small fw-semibold">
                        @Html.DisplayNameFor(model => model.approved_amount)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.approved_amount)
                    </dd>
                </dl>

                <form asp-action="Delete" method="post" class="d-flex justify-content-end gap-2">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-danger">
                        Yes, delete this beneficiary
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
