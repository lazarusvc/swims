@{
    // Titles / text
    var title = ViewData["BreadcrumbTitle"] as string ?? ViewData["title"] as string ?? "";
    var subTitle = ViewData["BreadcrumbSubTitle"] as string ?? ViewData["subTitle"] as string ?? "";
    var description = ViewData["BreadcrumbDescription"] as string
                      ?? ViewData["description"] as string
                      ?? "";

    // Root crumb
    var rootTitle = ViewData["BreadcrumbRootTitle"] as string ?? "SWIMS";
    var rootArea = ViewData["BreadcrumbRootArea"] as string ?? "";
    var rootController = ViewData["BreadcrumbRootController"] as string ?? "Home";
    var rootAction = ViewData["BreadcrumbRootAction"] as string ?? "Index";
    var rootRouteValues = ViewData["BreadcrumbRootRouteValues"];

    // Parent crumb (optional)
    var parentTitle = ViewData["BreadcrumbParentTitle"] as string;
    var parentArea = ViewData["BreadcrumbParentArea"] as string;
    var parentController = ViewData["BreadcrumbParentController"] as string;
    var parentAction = ViewData["BreadcrumbParentAction"] as string ?? "Index";
    var parentRouteValues = ViewData["BreadcrumbParentRouteValues"];

    // Current crumb (defaults to current route if not explicitly set)
    var currentTitle = ViewData["BreadcrumbCurrentTitle"] as string ?? title;
    var currentArea = ViewData["BreadcrumbCurrentArea"] as string
                      ?? (ViewContext.RouteData.Values["area"] as string ?? "");
    var currentController = ViewData["BreadcrumbCurrentController"] as string
                            ?? (ViewContext.RouteData.Values["controller"]?.ToString() ?? "");
    var currentAction = ViewData["BreadcrumbCurrentAction"] as string
                        ?? (ViewContext.RouteData.Values["action"]?.ToString() ?? "");
    var currentRouteValues = ViewData["BreadcrumbCurrentRouteValues"];

    // Helper to choose routeValues object (either provided or just area)
    object RootRoute() => rootRouteValues ?? (string.IsNullOrEmpty(rootArea) ? null : new { area = rootArea });
    object ParentRoute() => parentRouteValues ?? (string.IsNullOrEmpty(parentArea) ? null : new { area = parentArea });
    object CurrentRoute() => currentRouteValues ?? (string.IsNullOrEmpty(currentArea) ? null : new { area = currentArea });

    string rootUrl = null;
    if (!string.IsNullOrEmpty(rootController) && !string.IsNullOrEmpty(rootAction))
    {
        rootUrl = Url.Action(rootAction, rootController, RootRoute());
    }

    string parentUrl = null;
    if (!string.IsNullOrEmpty(parentTitle) && !string.IsNullOrEmpty(parentController))
    {
        parentUrl = Url.Action(parentAction, parentController, ParentRoute());
    }

    string currentUrl = null;
    if (!string.IsNullOrEmpty(currentController) && !string.IsNullOrEmpty(currentAction))
    {
        currentUrl = Url.Action(currentAction, currentController, CurrentRoute());
    }
}

<div class="mb-24">
    <!-- Title area + breadcrumb on the same row -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div>
            @* Subtitle as small eyebrow label above the title *@
            @if (!string.IsNullOrEmpty(subTitle))
            {
                <p class="mb-1 text-uppercase text-muted fs-12 fw-semibold">
                    @subTitle
                </p>
            }

            @if (!string.IsNullOrEmpty(title))
            {
                <h4 class="mb-0">@title</h4>
            }
        </div>

        <div class="d-flex align-items-center gap-1 text-muted fs-14">
            <iconify-icon icon="lucide:layout-dashboard" class="fs-16 me-1"></iconify-icon>

            @* Root *@
            @if (!string.IsNullOrEmpty(rootTitle))
            {
                if (!string.IsNullOrEmpty(rootUrl))
                {
                    <a href="@rootUrl" class="text-muted text-decoration-none fw-semibold">@rootTitle</a>
                }
                else
                {
                    <span class="fw-semibold">@rootTitle</span>
                }
            }

            @* Parent (optional) *@
            @if (!string.IsNullOrEmpty(parentTitle))
            {
                <span class="mx-1">/</span>
                @if (!string.IsNullOrEmpty(parentUrl))
                {
                    <a href="@parentUrl" class="text-muted text-decoration-none">@parentTitle</a>
                }
                else
                {
                    <span>@parentTitle</span>
                }
            }

            @* Current *@
            @if (!string.IsNullOrEmpty(currentTitle))
            {
                <span class="mx-1">/</span>
                @if (!string.IsNullOrEmpty(currentUrl))
                {
                    <a href="@currentUrl" class="text-muted text-decoration-none">@currentTitle</a>
                }
                else
                {
                    <span>@currentTitle</span>
                }
            }
        </div>
    </div>

    @* Description always gets its own full-width row under the title + breadcrumb *@
    @if (!string.IsNullOrEmpty(description))
    {
        <p class="text-sm text-muted mb-0 mt-1">
            @description
        </p>
    }
</div>
