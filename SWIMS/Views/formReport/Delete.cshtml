@model SWIMS.Models.SW_formReport

@{
    ViewData["Title"] = "Delete Form Report";
    ViewData["title"] = "Delete form report";
    ViewData["subTitle"] = "Confirm removal";
    ViewData["description"] = "Permanently remove this report configuration from the system.";
    ViewData["BreadcrumbParentTitle"] = "Form reports";
    ViewData["BreadcrumbParentController"] = "formReport";
    ViewData["BreadcrumbParentAction"] = "Index";
    ViewData["BreadcrumbCurrentTitle"] = "Delete form report";
}

<h6 style="color:red;">Are you sure you want to delete this?</h6>
<div class="card basic-data-table">
    <div class="card-header">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
        </form>
    </div>
    <div class="card-body" style="overflow-y:scroll; max-height: 250px;">
        <div>
         <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.url).ToUpper():
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.url)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SW_forms).ToUpper():
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SW_forms.name)
        </dd>
    </dl>
        </div>
    </div>
</div>
