@model SWIMS.Models.ViewModels.CaseDetailsViewModel
@using System.Collections.Generic

@{
    ViewData["Title"] = $"Case {Model.CaseNumber}";
    ViewData["title"] = "Cases";
    ViewData["subTitle"] = $"Case {Model.CaseNumber}";
    ViewData["description"] = "View case details, benefit period, linked forms and assigned workers.";

    ViewData["BreadcrumbParentTitle"] = "Cases";
    ViewData["BreadcrumbParentController"] = "Cases";
    ViewData["BreadcrumbParentAction"] = "Index";

    ViewData["BreadcrumbCurrentController"] = "Cases";
    ViewData["BreadcrumbCurrentAction"] = "Details";
    ViewData["BreadcrumbCurrentRouteValues"] = new Dictionary<string, string>
    {
        ["id"] = Model.Id.ToString()
    };

    var hasPrimaryApplication = Model.Forms?.Any(f => f.IsPrimary) == true;
}

@if (TempData["Ok"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        @ok
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-12 col-xl-8">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h5 class="card-title mb-0">@Model.Title</h5>
                    <p class="fs-12 text-muted mb-0">Case @Model.CaseNumber</p>
                </div>

                @{
                    var statusText = string.IsNullOrWhiteSpace(Model.Status)
                    ? "Pending"
                    : Model.Status.Trim();

                    var statusBadge = statusText switch
                    {
                        "Active" => "bg-success",
                        "Inactive" => "bg-danger",
                        "Suspended" => "bg-dark",
                        "Closed" => "bg-secondary",
                        "Pending" => "bg-warning",
                        _ => "bg-info"
                    };
                }

                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-soft-secondary btn-sm d-flex align-items-center gap-1">
                        <i class="ri-edit-line align-middle"></i>
                        <span>Edit</span>
                    </a>

                    <a asp-action="BenefitPeriod"
                       asp-route-id="@Model.Id"
                       class="btn btn-soft-info btn-sm d-flex align-items-center gap-1">
                        <i class="ri-timer-line align-middle"></i>
                        <span>Benefit period</span>
                    </a>

                    <form asp-action="RefreshFromPrimaryApplication"
                          asp-route-id="@Model.Id"
                          method="post"
                          class="d-inline">
                        @Html.AntiForgeryToken()

                        <button type="submit"
                                class="btn btn-soft-primary btn-sm d-flex align-items-center gap-1"
                                @(hasPrimaryApplication ? "" : "disabled")
                                aria-disabled="@(hasPrimaryApplication ? "false" : "true")">
                            <i class="ri-refresh-line align-middle"></i>
                            <span>Recalculate</span>
                        </button>

                        <sup class="ms-1">
                            <i class="ri-information-line text-muted"
                               role="button"
                               data-bs-toggle="tooltip"
                               data-bs-placement="top"
                               title="Recalculates benefit dates and computed case status from the Primary Application. If no Primary Application is linked, this is disabled. Manual status overrides remain in effect until cleared."></i>
                        </sup>
                    </form>

                    <span class="badge @statusBadge">
                        @statusText
                    </span>
                </div>
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Beneficiary</dt>
                    <dd class="col-sm-9">
                        <div class="d-flex flex-column">
                            <span>@Model.BeneficiaryName</span>
                            <span class="text-muted fs-11">@Model.BeneficiaryUuid</span>
                        </div>
                    </dd>

                    <dt class="col-sm-3">Programme</dt>
                    <dd class="col-sm-9">@Model.ProgramTag</dd>

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">
                        @Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        @if (!string.IsNullOrWhiteSpace(Model.CreatedBy))
                        {
                            <span class="text-muted fs-11">(@Model.CreatedBy)</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Closed</dt>
                    <dd class="col-sm-9">
                        @(Model.ClosedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—")
                    </dd>

                    <dt class="col-sm-3">Benefit period</dt>
                    <dd class="col-sm-9">
                        <div class="d-flex flex-column">
                            <span class="fw-semibold">
                                @(Model.BenefitStartAt.HasValue? Model.BenefitStartAt.Value.ToLocalTime().ToString("yyyy-MM-dd") : "—")
                                <span class="text-muted mx-1">→</span>
                                @(Model.BenefitEndAt.HasValue? Model.BenefitEndAt.Value.ToLocalTime().ToString("yyyy-MM-dd") : "—")
                            </span>

                            <span class="text-muted fs-11">
                                Months:
                                <span class="fw-semibold text-body">
                                    @(Model.BenefitPeriodMonths?.ToString() ?? "—")
                                </span>
                                <span class="mx-1">•</span>
                                Source:
                                <span class="fw-semibold text-body">
                                    @(string.IsNullOrWhiteSpace(Model.BenefitPeriodSource) ? "—" : Model.BenefitPeriodSource)
                                </span>
                            </span>

                            @if (Model.BenefitStartAtOverride.HasValue || Model.BenefitEndAtOverride.HasValue || Model.BenefitPeriodMonthsOverride.HasValue)
                            {
                                <span class="mt-1">
                                    <span class="badge bg-info">Overrides applied</span>
                                    <span class="text-muted fs-11 ms-2">
                                        @(Model.BenefitStartAtOverride.HasValue ? $"Start: {Model.BenefitStartAtOverride.Value.ToLocalTime():yyyy-MM-dd}" : "")
                                        @(Model.BenefitEndAtOverride.HasValue ? $" End: {Model.BenefitEndAtOverride.Value.ToLocalTime():yyyy-MM-dd}" : "")
                                        @(Model.BenefitPeriodMonthsOverride.HasValue ? $" Months: {Model.BenefitPeriodMonthsOverride.Value}" : "")
                                    </span>
                                </span>
                            }
                        </div>
                    </dd>

                    <dt class="col-sm-3">Notes</dt>
                    <dd class="col-sm-9">
                        @(!string.IsNullOrWhiteSpace(Model.Notes) ? Model.Notes : "—")
                    </dd>

                    <dt class="col-sm-3">Status actions</dt>
                    <dd class="col-sm-9">

                        @* Manual override banner *@
                        @if (!string.IsNullOrWhiteSpace(Model.StatusOverride))
                        {
                            var isActive = Model.IsStatusOverrideActive;
                            <div class="alert @(isActive ? "alert-warning" : "alert-secondary") py-2 px-3 mb-2">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                    <div class="fs-12">
                                        <strong>Manual status override @(isActive ? "active" : "present"):</strong>
                                        <span class="ms-1">@Model.StatusOverride</span>

                                        @if (!string.IsNullOrWhiteSpace(Model.StatusOverrideReason))
                                        {
                                            <span class="text-muted ms-2">— @Model.StatusOverrideReason</span>
                                        }

                                        @if (Model.StatusOverrideUntil.HasValue)
                                        {
                                            <span class="text-muted ms-2">
                                                (until @Model.StatusOverrideUntil.Value.ToLocalTime().ToString("yyyy-MM-dd"))
                                            </span>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(Model.StatusOverrideBy) || Model.StatusOverrideAt.HasValue)
                                        {
                                            <span class="text-muted ms-2">
                                                @if (!string.IsNullOrWhiteSpace(Model.StatusOverrideBy))
                                                {
                                                    <span>by @Model.StatusOverrideBy</span>
                                                }
                                                @if (Model.StatusOverrideAt.HasValue)
                                                {
                                                    <span>@(string.IsNullOrWhiteSpace(Model.StatusOverrideBy) ? "" : ", ")@Model.StatusOverrideAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                                }
                                            </span>
                                        }
                                    </div>

                                    <form asp-action="ClearStatusOverride" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-soft-dark">
                                            <i class="ri-close-circle-line align-middle"></i> Clear override
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }

                        <div class="d-flex flex-wrap gap-2">
                            @if (Model.Status != "Pending")
                            {
                                <form asp-action="SetStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="status" value="Pending" />
                                    <input type="hidden" name="reason" value="Manual override via Case Details" />
                                    <button type="submit" class="btn btn-soft-warning btn-sm">
                                        <i class="ri-time-line align-middle"></i> Mark pending
                                    </button>
                                </form>
                            }

                            @if (Model.Status != "Active")
                            {
                                <form asp-action="SetStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="status" value="Active" />
                                    <input type="hidden" name="reason" value="Manual override via Case Details" />
                                    <button type="submit" class="btn btn-soft-success btn-sm">
                                        <i class="ri-play-circle-line align-middle"></i> Mark active
                                    </button>
                                </form>
                            }

                            @if (Model.Status != "Inactive")
                            {
                                <form asp-action="SetStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="status" value="Inactive" />
                                    <input type="hidden" name="reason" value="Manual override via Case Details" />
                                    <button type="submit" class="btn btn-soft-danger btn-sm">
                                        <i class="ri-stop-circle-line align-middle"></i> Mark inactive
                                    </button>
                                </form>
                            }

                            @if (Model.Status != "Suspended")
                            {
                                <form asp-action="SetStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="status" value="Suspended" />
                                    <input type="hidden" name="reason" value="Manual override via Case Details" />
                                    <button type="submit" class="btn btn-soft-dark btn-sm">
                                        <i class="ri-pause-circle-line align-middle"></i> Suspend
                                    </button>
                                </form>
                            }

                            @if (Model.Status != "Closed")
                            {
                                <form asp-action="SetStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="status" value="Closed" />
                                    <input type="hidden" name="reason" value="Manual override via Case Details" />
                                    <button type="submit" class="btn btn-soft-secondary btn-sm">
                                        <i class="ri-lock-line align-middle"></i> Close case
                                    </button>
                                </form>
                            }
                        </div>
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card basic-data-table mb-3">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h5 class="card-title mb-0">Forms on this case</h5>
                    <small class="text-muted">Attach existing submissions or start new ones for this beneficiary.</small>
                </div>

                <div class="btn-group btn-group-sm">
                    <a asp-action="LinkForm"
                       asp-route-id="@Model.Id"
                       class="btn btn-primary d-flex align-items-center gap-1">
                        <i class="mdi mdi-link-variant"></i>
                        <span>Link existing</span>
                    </a>

                    <a asp-controller="Home"
                       asp-action="Index"
                       asp-route-caseId="@Model.Id"
                       asp-route-beneficiaryId="@Model.BeneficiaryId"
                       class="btn btn-outline-secondary d-flex align-items-center gap-1">
                        <i class="mdi mdi-file-plus-outline"></i>
                        <span>Start new form</span>
                    </a>
                </div>
            </div>

            <div class="card-body">
                @if (Model.Forms.Any())
                {
                    <div class="table-responsive">
                        <table class="table bordered-table mb-0 align-middle w-100"
                               id="caseFormsTable"
                               data-page-length="10">
                            <thead>
                                <tr>
                                    <th>Role</th>
                                    <th style="width: 80px;">Primary</th>
                                    <th>Linked at</th>
                                    <th>Linked by</th>
                                    <th>Form</th>
                                    <th style="width: 120px;">Form entry</th>
                                    <th>Form Type</th>
                                    <th>Program Tags</th>
                                    <th>Site Identity</th>
                                    <th class="text-center" style="width: 130px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var f in Model.Forms)
                                {
                                    <tr>
                                        <td>@f.Role</td>
                                        <td>@(f.IsPrimary ? "Yes" : "No")</td>
                                        <td>@(f.LinkedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                                        <td>@f.LinkedBy</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(f.FormName))
                                            {
                                                @f.FormName
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="text-xs text-muted">
                                                Entry #@f.FormTableDataId
                                            </span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(f.FormTypeName))
                                            {
                                                <span class="badge bg-secondary">@f.FormTypeName</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (f.ProgramTagNames != null && f.ProgramTagNames.Count > 0)
                                            {
                                                foreach (var t in f.ProgramTagNames)
                                                {
                                                    <span class="badge bg-info me-1">@t</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(f.SiteIdentityName))
                                            {
                                                @f.SiteIdentityName
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="text-center align-middle">
                                            <div class="d-flex align-items-center gap-10 justify-content-center">
                                                <a asp-controller="Cases"
                                                   asp-action="FormPreview"
                                                   asp-route-id="@f.Id"
                                                   class="bg-info-focus bg-hover-info-200 text-info-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                                   title="Preview form" aria-label="Preview form">
                                                    <iconify-icon icon="ion:eye-outline"></iconify-icon>
                                                </a>

                                                <a asp-controller="Cases"
                                                   asp-action="FormEdit"
                                                   asp-route-id="@f.Id"
                                                   class="bg-success-focus bg-hover-success-200 text-success-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                                   title="Edit form" aria-label="Edit form">
                                                    <iconify-icon icon="lucide:edit-3"></iconify-icon>
                                                </a>

                                                <form asp-action="DetachForm"
                                                      asp-route-id="@f.Id"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="remove-item-btn bg-danger-focus bg-hover-danger-200 text-danger-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle border-0"
                                                            title="Remove from case"
                                                            aria-label="Remove from case"
                                                            onclick="return confirm('Remove this form from the case? The underlying submission will not be deleted.');">
                                                        <iconify-icon icon="ri:link-unlink-m"></iconify-icon>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">
                        No forms are linked to this case yet.
                    </p>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Assigned workers</h5>
                <a asp-action="Assign"
                   asp-route-id="@Model.Id"
                   class="btn btn-sm btn-soft-primary d-flex align-items-center gap-1">
                    <i class="ri-user-add-line align-middle"></i>
                    <span>Assign</span>
                </a>
            </div>
            <div class="card-body">
                @if (Model.Assignments.Any())
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var a in Model.Assignments)
                        {
                            var badgeClass = a.IsActive ? "bg-success" : "bg-secondary";

                            <li class="mb-3">
                                <div class="d-flex justify-content-between">
                                    <div class="me-2">
                                        <div title="@a.UserId">
                                            <span class="fw-semibold">
                                                @a.UserDisplayName
                                            </span>

                                            @if (!string.IsNullOrWhiteSpace(a.SystemRoles))
                                            {
                                                <span class="text-muted fs-11 ms-1">
                                                    (System: @a.SystemRoles)
                                                </span>
                                            }
                                    </div>
                                </div>

                                <span class="badge @badgeClass">
                                    @(a.IsActive ? "Active" : "Inactive")
                                </span>
                            </div>

                            <div class="d-flex justify-content-between text-muted fs-11">
                                <span>
                                    Case role:
                                    @(string.IsNullOrWhiteSpace(a.RoleOnCase) ? "—" : a.RoleOnCase)
                                </span>
                                <span>
                                    @(a.AssignedAt.HasValue
                                                                    ? a.AssignedAt.Value.ToLocalTime().ToString("yyyy-MM-dd")
                                                                    : "-")
                                    </span>
                                </div>

                                @if (a.IsActive)
                                {
                                    <div class="mt-1">
                                        <form asp-action="UnassignWorker"
                                              method="post"
                                              class="d-inline">
                                            <input type="hidden" name="id" value="@a.Id" />
                                            <button type="submit"
                                                    class="btn btn-link btn-sm text-danger p-0"
                                                    onclick="return confirm('Remove this worker from the case?');">
                                                <i class="ri-user-unfollow-line align-middle me-1"></i>
                                                Remove
                                            </button>
                                        </form>
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">
                        No staff are assigned to this case yet.
                    </p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.bootstrap && bootstrap.Tooltip) {
                var triggers = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
                triggers.forEach(function (el) { new bootstrap.Tooltip(el); });
            }

            if (window.DataTable) {
                const caseFormsTable = new DataTable('#caseFormsTable');
            }
        });
    </script>
}
