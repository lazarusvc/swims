@model SWIMS.Models.ViewModels.CaseLinkFormViewModel
@using System.Collections.Generic

@{
    ViewData["Title"] = "Link form to case";
    ViewData["title"] = "Cases";
    ViewData["subTitle"] = "Link form";
    ViewData["description"] = "Attach an existing form submission to this case.";

    ViewData["BreadcrumbParentText"] = "Case details";
    ViewData["BreadcrumbParentController"] = "Cases";
    ViewData["BreadcrumbParentAction"] = "Details";
    ViewData["BreadcrumbParentRouteValues"] = new Dictionary<string, string>
    {
        ["id"] = Model.SW_caseId.ToString()
    };

    ViewData["BreadcrumbCurrentController"] = "Cases";
    ViewData["BreadcrumbCurrentAction"] = "LinkForm";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h5 class="card-title mb-0">Link form to case</h5>
                    <p class="fs-12 text-muted mb-0">
                        Case @Model.CaseNumber — @Model.CaseTitle
                    </p>
                </div>
                <a asp-action="Details"
                   asp-route-id="@Model.SW_caseId"
                   class="btn btn-sm btn-soft-secondary d-flex align-items-center gap-1">
                    <i class="ri-arrow-left-line align-middle"></i>
                    <span>Back to case</span>
                </a>
            </div>

            <div class="card-body">
                <form asp-action="LinkForm" asp-route-id="@Model.SW_caseId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="SW_caseId" />

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    @if (ViewBag.FormScopeNote != null)
                    {
                        <div class="alert alert-info mb-3">@ViewBag.FormScopeNote</div>
                    }

                    @{
                        var hasSelectable =
                        Model.AvailableForms != null &&
                        Model.AvailableForms.Any(x => !x.Disabled && !string.IsNullOrWhiteSpace(x.Value));
                    }

                    @if (!hasSelectable)
                    {
                        <div class="alert alert-warning">
                            No submissions found for this beneficiary.
                            <br />
                            If this is unexpected, confirm the submission has a <strong>beneficiary</strong> field and it matches the case beneficiary.
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="SelectedFormTableDatumId" class="form-label"></label>
                        <select asp-for="SelectedFormTableDatumId"
                                asp-items="Model.AvailableForms"
                                class="form-select">
                            <option value="">-- Select a form submission --</option>
                        </select>
                        <span asp-validation-for="SelectedFormTableDatumId" class="text-danger"></span>

                        @if (ViewBag.FormScopeNote is string scopeNote && !string.IsNullOrWhiteSpace(scopeNote))
                        {
                            <div class="form-text">@scopeNote</div>
                        }

                        <div class="form-text">
                            Showing the most recent form submissions. Later we can add filters by form or beneficiary.
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6 d-flex align-items-center">
                            <div class="form-check mt-3">
                                <input asp-for="IsPrimaryApplication" class="form-check-input" />
                                <label asp-for="IsPrimaryApplication" class="form-check-label"></label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-3">
                                <input asp-for="IncludeLinkedForms" type="hidden" value="false" />
                                <label asp-for="IncludeLinkedForms" class="form-check-label"></label>
                                <div class="form-text">
                                    When checked, any linked child/sub-forms can also be attached to this case
                                    once the linking metadata is wired up.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Details"
                           asp-route-id="@Model.SW_caseId"
                           class="btn btn-soft-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary d-flex align-items-center gap-1">
                            <i class="ri-link align-middle"></i>
                            <span>Link form</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
