@model SWIMS.Models.ViewModels.CaseLinkFormViewModel

@{
    ViewData["Title"] = "Link form to case";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="card-title mb-0">Link form to case</h4>
                    <p class="fs-12 text-muted mb-0">
                        Case @Model.CaseNumber — @Model.CaseTitle
                    </p>
                </div>
                <a asp-action="Details"
                   asp-route-id="@Model.SW_caseId"
                   class="btn btn-sm btn-soft-secondary">
                    <i class="ri-arrow-left-line align-middle"></i> Back to case
                </a>
            </div>

            <div class="card-body">
                <form asp-action="LinkForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="SW_caseId" />

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="SelectedFormTableDatumId" class="form-label"></label>
                        <select asp-for="SelectedFormTableDatumId"
                                asp-items="Model.AvailableForms"
                                class="form-select">
                            <option value="">-- Select a form submission --</option>
                        </select>
                        <span asp-validation-for="SelectedFormTableDatumId" class="text-danger"></span>
                        <div class="form-text">
                            Showing the most recent form submissions. Later we can add filters by form or beneficiary.
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FormRole" class="form-label"></label>
                            <select asp-for="FormRole" class="form-select">
                                <option value="">(none)</option>
                                <option value="Application">Application</option>
                                <option value="Intake">Intake</option>
                                <option value="Assessment">Assessment</option>
                                <option value="Dependent">Dependent</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="FormRole" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 d-flex align-items-center">
                            <div class="form-check mt-3">
                                <input asp-for="IsPrimaryApplication" class="form-check-input" />
                                <label asp-for="IsPrimaryApplication" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Details"
                           asp-route-id="@Model.SW_caseId"
                           class="btn btn-soft-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="ri-link align-middle"></i> Link form
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
