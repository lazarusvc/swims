@model SWIMS.Models.ViewModels.CaseIndexViewModel
@using System.Collections.Generic

@{
    ViewData["Title"] = "Cases";
    ViewData["title"] = "Cases";
    ViewData["subTitle"] = "All cases";
    ViewData["description"] = "Each case groups applications, assessments and follow-up for one beneficiary.";

    ViewData["BreadcrumbCurrentController"] = "Cases";
    ViewData["BreadcrumbCurrentAction"] = "Index";
}

@if (TempData["Ok"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        @ok
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="card basic-data-table">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h5 class="card-title mb-0">Cases</h5>
                    <p class="text-muted mb-0 fs-12">
                        Use filters to narrow down by programme, status or text search.
                    </p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <form asp-action="Index" method="get" class="d-flex flex-wrap gap-2">
                        <input type="text"
                               name="search"
                               value="@Model.SearchText"
                               class="form-control form-control-sm"
                               placeholder="Search case #, title, beneficiary..." />

                        <div class="col-sm-3 col-md-2">
                            <label class="form-label mb-0" for="cases-program">Programme</label>
                            <select id="cases-program" name="program" class="form-select form-select-sm">
                                <option value="">All programmes</option>
                                @foreach (var opt in Model.ProgramOptions)
                                {
                                    <option value="@opt.Value" selected="@(opt.Selected ? "selected" : null)">
                                        @opt.Text
                                    </option>
                                }
                            </select>
                        </div>

                        <select name="status" class="form-select form-select-sm">
                            <option value="">All statuses</option>
                            <option value="Pending" selected="@(Model.StatusFilter == "Pending" ? "selected" : null)">Pending</option>
                            <option value="Active" selected="@(Model.StatusFilter == "Active" ? "selected" : null)">Active</option>
                            <option value="Inactive" selected="@(Model.StatusFilter == "Inactive" ? "selected" : null)">Inactive</option>
                            <option value="Closed" selected="@(Model.StatusFilter == "Closed" ? "selected" : null)">Closed</option>
                        </select>

                        <button type="submit" class="btn btn-sm btn-primary d-flex align-items-center gap-1">
                            <i class="ri-filter-2-line align-middle"></i>
                            <span>Filter</span>
                        </button>
                    </form>

                    <a asp-action="Create"
                       class="btn btn-sm btn-primary d-flex align-items-center gap-1">
                        <iconify-icon icon="lucide:plus" class="fs-14"></iconify-icon>
                        <span>New case</span>
                    </a>
                </div>
            </div>

            <div class="card-body">
                @if (Model.Cases.Any())
                {
                    <div class="table-responsive">
                        <table class="table bordered-table mb-0 align-middle w-100"
                               id="casesTable"
                               data-page-length="10">
                            <thead>
                                <tr>
                                    <th style="width: 110px;">Case #</th>
                                    <th>Title</th>
                                    <th>Beneficiary</th>
                                    <th style="width: 110px;">Status</th>
                                    <th>Programme</th>
                                    <th style="width: 170px;">Created</th>
                                    <th class="text-center" style="width: 90px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Cases)
                                {
                                    var statusText = string.IsNullOrWhiteSpace(c.Status)
                                    ? "Pending"
                                    : c.Status.Trim();

                                    var statusBadge = statusText switch
                                    {
                                        "Active" => "bg-success",
                                        "Inactive" => "bg-danger",
                                        "Closed" => "bg-secondary",
                                        "Pending" => "bg-warning",
                                        _ => "bg-info"
                                    };

                                    <tr>
                                        <td class="fw-semibold">@c.CaseNumber</td>
                                        <td>@c.Title</td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <span>@c.BeneficiaryName</span>
                                                <span class="text-muted fs-11">@c.BeneficiaryUuid</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge @statusBadge">
                                                @statusText
                                            </span>
                                        </td>
                                        <td>@c.ProgramTag</td>
                                        <td>@c.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                        <td class="text-center align-middle">
                                            <div class="d-flex align-items-center gap-10 justify-content-center">
                                                <a asp-action="Details"
                                                   asp-route-id="@c.Id"
                                                   class="bg-primary-focus bg-hover-primary-200 text-primary-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                                   title="View case" aria-label="View case">
                                                    <iconify-icon icon="iconamoon:eye-light"></iconify-icon>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">
                        No cases found yet.
                    </p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const casesTable = new DataTable('#casesTable');
    </script>
}
