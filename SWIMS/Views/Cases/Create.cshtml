@model SWIMS.Models.ViewModels.CaseCreateViewModel

@{
    ViewData["Title"] = "New case";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="card-title mb-0">New case</h4>
                    <p class="fs-12 text-muted mb-0">
                        Create a case to group application and assessment forms for a beneficiary.
                    </p>
                </div>
                <a asp-action="Index" class="btn btn-sm btn-soft-secondary">
                    <i class="ri-arrow-left-line align-middle"></i> Back to list
                </a>
            </div>

            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="CaseNumber" class="form-label"></label>
                            <input asp-for="CaseNumber" class="form-control" readonly />
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" readonly />
                            <div class="form-text">
                                This will automatically use the selected beneficiary's name.
                            </div>
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>


                        <div class="col-md-6">
                            <label asp-for="SW_beneficiaryId" class="form-label"></label>
                            <select asp-for="SW_beneficiaryId"
                                    asp-items="Model.Beneficiaries"
                                    class="form-select">
                                <option value="">-- Select beneficiary --</option>
                            </select>
                            <span asp-validation-for="SW_beneficiaryId" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Pending">Pending</option>
                                <option value="Active">Active</option>
                                <option value="Closed">Closed</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProgramTagId" class="form-label"></label>
                            <select asp-for="ProgramTagId"
                                    asp-items="Model.ProgramOptions"
                                    class="form-select">
                                <option value="">-- Select programme --</option>
                            </select>
                            <span asp-validation-for="ProgramTagId" class="text-danger"></span>
                        </div>


                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" rows="3" class="form-control"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-soft-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="ri-save-3-line align-middle"></i> Create case
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const beneficiarySelect = document.getElementById('SW_beneficiaryId');
            const titleInput = document.getElementById('Title');

            if (!beneficiarySelect || !titleInput) return;

            function syncTitleFromBeneficiary() {
                const selected = beneficiarySelect.options[beneficiarySelect.selectedIndex];
                if (!selected || !selected.value) {
                    titleInput.value = '';
                    return;
                }
                titleInput.value = selected.text.trim();
            }

            beneficiarySelect.addEventListener('change', syncTitleFromBeneficiary);
            // initial sync on load (in case something is preselected later)
            syncTitleFromBeneficiary();
        })();
    </script>
}

