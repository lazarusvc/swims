@model SWIMS.Models.SW_formTableName

@{
    ViewData["Title"] = "Table Definition Details";
    ViewData["title"] = "Table definition details";
    ViewData["subTitle"] = "View lookup schema";
    ViewData["description"] = "Review the name and field structure of this form lookup table definition.";
    ViewData["BreadcrumbParentTitle"] = "Form table definitions";
    ViewData["BreadcrumbParentController"] = "formTableName";
    ViewData["BreadcrumbParentAction"] = "Index";
    ViewData["BreadcrumbCurrentTitle"] = "Table definition details";
}

<br />
<div class="card basic-data-table">
    <div class="card-header">
        <a asp-action="Index" class="bg-primary-light text-primary-600 d-inline-flex align-items-center justify-content-center" style="padding: 10px;"> SW_formTableName listings</a>
    </div>
    <div class="card-body" style="overflow-y:scroll; max-height: 250px;">
     <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.name).ToUpper():
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.field).ToUpper():
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.field)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SW_forms).ToUpper():
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SW_forms.name)
        </dd>
    </dl>

    </div>
</div>

