{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../../",
          "files": [ "SWIMS.csproj" ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "dest": "../docs",
    "content": [
      {
        "files": [ "**/*.{md,yml}" ],
        "src": "."
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ],
        "src": "images"
      },
      {
        "files": [ "user-guide/toc.pdf" ]
      }
    ],
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appTitle": "SWIMS Developer Documentation",
      "_appName": "SWIMS",
      "_enableSearch": true,
      "_disableContribution": true,
      "pdf": true
    }
  }
}